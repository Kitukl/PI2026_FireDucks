@model StudyHub.Core.DTOs.LessonDto

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center py-3">
                    <h5 class="mb-0">Інформація про заняття</h5>
                    <div>
                        <a asp-action="LessonEdit" asp-route-id="@Model.Id" class="btn btn-sm btn-light">Редагувати</a>
                        <a asp-action="LessonsList" class="btn btn-sm btn-outline-light">Назад</a>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row mb-4">
                        <div class="col-sm-4 text-muted">Предмет:</div>
                        <div class="col-sm-8 fw-bold fs-5">@Model.Subject.Name</div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted">Час проведення:</div>
                        <div class="col-sm-8">
                            <span class="badge bg-light text-dark border">
                                @GetDayName((int)Model.Day), @Model.LessonSlot.StartTime.ToString("HH:mm") - @Model.LessonSlot.EndTime.ToString("HH:mm")
                            </span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-sm-4 text-muted">Тип заняття:</div>
                        <div class="col-sm-8 text-uppercase">@Model.LessonType</div>
                    </div>

                    <hr />

                    <h6 class="mb-3 text-primary">Викладацький склад:</h6>
                    <ul class="list-group list-group-flush">
                        @foreach (var lecturer in Model.Lecturers)
                        {
                            <li class="list-group-item d-flex align-items-center">
                                <i class="bi bi-person-badge me-2"></i>
                                <span>@lecturer.Surname @lecturer.Name</span>
                                <a asp-controller="Lecturer" asp-action="LecturerDetails" asp-route-id="@lecturer.Id" class="ms-auto btn btn-link btn-sm p-0">Профіль</a>
                            </li>
                        }
                    </ul>
                </div>
                <div class="card-footer bg-transparent text-muted small">
                    System ID: @Model.Id
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    string GetDayName(int day) => day switch
    {
        1 => "Понеділок",
        2 => "Вівторок",
        3 => "Середа",
        4 => "Четвер",
        5 => "П'ятниця",
        6 => "Субота",
        7 => "Неділя",
        _ => "Невідомо"
    };
}