@model StudyHub.Core.DTOs.LessonDto

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white py-3 text-center">
                    <h5 class="mb-0">Параметри нового заняття</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Предмет</label>
                                <select asp-for="Subject.Id" asp-items="ViewBag.Subjects" class="form-select">
                                    <option value="">-- Оберіть предмет --</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Часовий слот</label>
                                <select asp-for="LessonSlot.Id" asp-items="ViewBag.Slots" class="form-select">
                                    <option value="">-- Оберіть час --</option>
                                </select>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Day" class="form-label fw-bold">День тижня</label>
                                <select asp-for="Day" class="form-select">
                                    <option value="1">Понеділок</option>
                                    <option value="2">Вівторок</option>
                                    <option value="3">Середа</option>
                                    <option value="4">Четвер</option>
                                    <option value="5">П'ятниця</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="LessonType" class="form-label fw-bold">Тип (Лекція/Практика)</label>
                                <input asp-for="LessonType" class="form-control" placeholder="Напр: Лекція" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Викладачі (можна обрати декількох)</label>
                            <select name="LecturersIds" asp-items="ViewBag.Lecturers" class="form-select" multiple style="height: 120px;"></select>
                            <small class="text-muted">Утримуйте Ctrl для вибору кількох осіб</small>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="LessonsList" class="btn btn-outline-secondary">Назад</a>
                            <button type="submit" class="btn btn-primary px-5">Створити заняття</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>