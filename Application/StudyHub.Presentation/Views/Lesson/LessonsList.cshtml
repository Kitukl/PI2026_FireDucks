@model IEnumerable<StudyHub.Core.DTOs.LessonDto>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Усі заняття</h2>
        <a asp-action="LessonsCreate" class="btn btn-primary">Створити заняття</a>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>Предмет</th>
                    <th>День</th>
                    <th>Час</th>
                    <th>Тип</th>
                    <th>Викладачі</th>
                    <th class="text-center">Дії</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">@item.Subject.Name</td>
                        <td>@GetDayName((int)item.Day)</td>
                        <td>@item.LessonSlot.StartTime.ToString("HH:mm")</td>
                        <td><span class="badge bg-secondary">@item.LessonType</span></td>
                        <td>
                            @string.Join(", ", item.Lecturers.Select(l => l.Surname))
                        </td>
                        <td class="text-center">
                            <a asp-action="LessonsEdit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Редагувати</a>
                            <form asp-action="LessonDelete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Видалити?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Видалити</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@functions {
    string GetDayName(int day) => day switch
    {
        1 => "Пн",
        2 => "Вт",
        3 => "Ср",
        4 => "Чт",
        5 => "Пт",
        6 => "Сб",
        7 => "Нд",
        _ => "?"
    };
}