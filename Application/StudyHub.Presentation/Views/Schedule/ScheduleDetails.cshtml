@model StudyHub.Core.DTOs.ScheduleDto

@{
    ViewData["Title"] = "Schedule details - " + Model.Group.Name;
    Layout = "_Layout";
    var lessonsByDay = Model.Lessons
        .GroupBy(l => l.Day)
        .OrderBy(g => g.Key)
        .ToList();
}

<section class="admin-page" aria-label="Schedule details page">
    <div class="admin-page-header admin-page-header-inline">
        <div>
            <h1>Schedule details</h1>
            <p class="admin-page-subtitle">Group @Model.Group.Name · Updated at @Model.UpdateAt.ToString("g")</p>
        </div>
        <div class="admin-actions-inline">
            <a asp-action="ScheduleEdit" asp-route-id="@Model.Id" class="admin-btn admin-btn-primary">Edit</a>
            <a asp-action="SchedulesList" class="admin-btn">Back to group list</a>
        </div>
    </div>

    <div class="admin-panel">
        <div class="admin-inline-details">
            <div><strong>Mode:</strong> @(Model.IsAutoUpdate ? "Auto update" : "Manual update")</div>
            <div><strong>Leader access:</strong> @(Model.LeaderUpdate ? "Enabled" : "Disabled")</div>
            <div><strong>Lessons count:</strong> @Model.Lessons.Count</div>
        </div>
    </div>

    @if (!Model.Lessons.Any())
    {
        <div class="admin-panel">
            <p class="admin-page-subtitle">This schedule has no lessons yet. Add lessons in edit mode.</p>
        </div>
    }
    else
    {
        <div class="admin-day-grid">
            @foreach (var dayGroup in lessonsByDay)
            {
                <article class="admin-panel">
                    <header class="admin-panel-head">
                        <h2>@GetDayName((int)dayGroup.Key)</h2>
                    </header>

                    <div class="admin-day-list">
                        @foreach (var lesson in dayGroup.OrderBy(l => l.LessonSlot.StartTime))
                        {
                            <article class="admin-day-item">
                                <p class="admin-day-time">
                                    @lesson.LessonSlot.StartTime.ToString("HH:mm") - @lesson.LessonSlot.EndTime.ToString("HH:mm")
                                </p>
                                <h3>@lesson.Subject.Name</h3>
                                <p>Type: @lesson.LessonType</p>
                                <p>
                                    Lecturers:
                                    @if (lesson.Lecturers.Any())
                                    {
                                        @string.Join(", ", lesson.Lecturers.Select(lect => $"{lect.Surname} {lect.Name[0]}."))
                                    }
                                    else
                                    {
                                        @:Not specified
                                    }
                                </p>
                            </article>
                        }
                    </div>
                </article>
            }
        </div>
    }
</section>

@functions {
    string GetDayName(int day) => day switch
    {
        1 => "Monday",
        2 => "Tuesday",
        3 => "Wednesday",
        4 => "Thursday",
        5 => "Friday",
        6 => "Saturday",
        7 => "Sunday",
        _ => "Unknown day"
    };
}