@model StudyHub.Core.DTOs.ScheduleDto

<div class="container mt-4">
    <h2>Налаштування розкладу: @Model.Group.Name</h2>
    <hr />

    <form asp-action="Edit">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="Group.Id" />

        <div class="row mb-4">
            <div class="col-md-4">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" asp-for="HeadmanUpdate">
                    <label class="form-check-label" asp-for="HeadmanUpdate">Дозволити старості редагувати</label>
                </div>
                <div class="form-check form-switch mt-2">
                    <input class="form-check-input" type="checkbox" asp-for="IsAutoUpdate">
                    <label class="form-check-label" asp-for="IsAutoUpdate">Автоматичне оновлення</label>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Заняття в розкладі</h5>
                <button type="button" id="addExistingLesson" class="btn btn-success btn-sm">+ Додати існуючий урок</button>
            </div>
            <div class="card-body">
                <table class="table" id="scheduleLessonsTable">
                    <thead>
                        <tr>
                            <th>Урок (Предмет, Тип, День)</th>
                            <th>Дія</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Lessons.Count; i++)
                        {
                            <tr>
                                <td>
                                    <input type="hidden" name="Lessons[@i].Id" value="@Model.Lessons[i].Id" />
                                    <span>@Model.Lessons[i].Subject.Name (@Model.Lessons[i].LessonType) - День @Model.Lessons[i].Day</span>
                                </td>
                                <td>
                                    <button type="button" class="btn btn-danger btn-sm remove-lesson">Видалити</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-primary px-5">Зберегти розклад</button>
            <a asp-action="SchedulesList" class="btn btn-link">До списку груп</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        let lessonCount = @Model.Lessons.Count;

        $("#addExistingLesson").click(function () {
            let lessonId = prompt("Введіть ID уроку або виберіть зі списку (спрощено)");
            if (lessonId) {
                let row = `<tr>
                    <td>
                        <input type="hidden" name="Lessons[${lessonCount}].Id" value="${lessonId}" />
                        <span>Новий обраний урок (ID: ${lessonId})</span>
                    </td>
                    <td><button type="button" class="btn btn-danger btn-sm remove-lesson">Видалити</button></td>
                </tr>`;
                $("#scheduleLessonsTable tbody").append(row);
                lessonCount++;
            }
        });

        $(document).on("click", ".remove-lesson", function () {
            $(this).closest("tr").remove();
        });
    </script>
}