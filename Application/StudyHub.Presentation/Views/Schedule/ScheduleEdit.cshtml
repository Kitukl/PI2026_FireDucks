@model StudyHub.Core.DTOs.ScheduleDto

@{
    Layout = "_Layout";
    ViewData["Title"] = "Edit schedule";
}

<section class="admin-page" aria-label="Edit schedule page">
    <div class="admin-page-header">
        <div>
            <h1>Edit schedule</h1>
            <p class="admin-page-subtitle">Group: @Model.Group.Name</p>
        </div>
    </div>

    <form asp-action="ScheduleEdit" class="admin-form-stack">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="Group.Id" />
        <input type="hidden" asp-for="Group.Name" />

        <div class="admin-panel admin-switch-grid">
            <label class="admin-switch-item">
                <input type="checkbox" asp-for="HeadmanUpdate">
                <span>Allow headman editing</span>
            </label>
            <label class="admin-switch-item">
                <input type="checkbox" asp-for="IsAutoUpdate">
                <span>Auto update</span>
            </label>
            <div asp-validation-summary="All" class="text-danger"></div>
        </div>

        <div class="admin-panel">
            <div class="admin-page-header admin-page-header-inline">
                <h2>Lessons in schedule</h2>
                <button type="button" class="admin-btn admin-btn-primary" data-bs-toggle="modal" data-bs-target="#lessonModal">
                    Add existing lesson
                </button>
            </div>
            <div class="admin-table-wrap">
                <table class="admin-table" id="scheduleLessonsTable">
                    <thead>
                        <tr>
                            <th>Lesson (subject, type, day)</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Lessons.Count; i++)
                        {
                            <tr>
                                <td>
                                    <input type="hidden" name="Lessons[@i].Id" value="@Model.Lessons[i].Id" />
                                    <span>@Model.Lessons[i].Subject.Name (@Model.Lessons[i].LessonType) - Day @Model.Lessons[i].Day</span>
                                </td>
                                <td>
                                    <button type="button" class="admin-link-btn admin-link-btn-danger remove-lesson">Remove</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="modal fade" id="lessonModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="admin-modal-head">
                        <h5 class="modal-title">Select lesson from list</h5>
                        <button type="button" class="admin-btn" data-bs-dismiss="modal" aria-label="Close">Close</button>
                    </div>
                    <div class="admin-modal-body">
                        <div class="list-group">
                            @foreach (var lesson in (SelectList)ViewBag.Lessons)
                            {
                                <button type="button" class="list-group-item list-group-item-action select-lesson-btn"
                                        data-id="@lesson.Value" data-text="@lesson.Text">
                                    @lesson.Text
                                </button>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="admin-actions-inline">
            <button type="submit" class="admin-btn admin-btn-primary">Save schedule</button>
            <a asp-action="SchedulesList" class="admin-btn">Back to group list</a>
        </div>
    </form>

</section>

@section Scripts {
    <script>
        let lessonCount = @Model.Lessons.Count;

        $(".select-lesson-btn").click(function () {
            const lessonId = $(this).data("id");
            const lessonText = $(this).data("text");

            const row = `<tr>
                <td>
                    <input type="hidden" name="Lessons[${lessonCount}].Id" value="${lessonId}" />
                    <span class="fw-bold text-primary">${lessonText}</span>
                </td>
                <td>
                    <button type="button" class="admin-link-btn admin-link-btn-danger remove-lesson">Remove</button>
                </td>
            </tr>`;

            $("#scheduleLessonsTable tbody").append(row);
            lessonCount++;

            bootstrap.Modal.getInstance(document.getElementById('lessonModal')).hide();
        });

        $(document).on("click", ".remove-lesson", function () {
            $(this).closest("tr").remove();
        });
    </script>
}