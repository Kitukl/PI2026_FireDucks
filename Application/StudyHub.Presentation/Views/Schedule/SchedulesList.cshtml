@model IEnumerable<StudyHub.Core.DTOs.ScheduleDto>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Розклади академічних груп</h2>
        <a asp-action="ScheduleCreate" class="btn btn-primary">Створити розклад</a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title text-primary">Група: @item.Group.Name</h5>
                        <p class="card-text text-muted">
                            Останнє оновлення: @item.UpdateAt.ToString("dd.MM.yyyy HH:mm")
                        </p>
                        <ul class="list-unstyled small">
                            <li><i class="bi bi-check2-circle text-success"></i> Уроків у базі: @item.Lessons.Count</li>
                            <li><i class="bi bi-shield-lock"></i> Права старости: @(item.HeadmanUpdate ? "Так" : "Ні")</li>
                        </ul>
                    </div>
                    <div class="card-footer bg-transparent border-top-0 d-flex justify-content-between">
                        <a asp-action="ScheduleEdit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Налаштувати</a>
                        <a asp-action="ScheduleDetails" asp-route-id="@item.Id" class="btn btn-sm btn-info">Переглянути</a>
                        <a asp-action="ScheduleDelete" asp-route-id="@item.Id" class="btn btn-sm btn-info">Видалити</a>
                        <form asp-action="ScheduleDelete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Видалити розклад цієї групи?')">
                            <button type="submit" class="btn btn-sm btn-link text-danger p-0"><i class="bi bi-trash"></i></button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>