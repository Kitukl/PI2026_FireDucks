@model IEnumerable<StudyHub.Core.DTOs.ScheduleDto>

@{
    Layout = "_Layout";
    ViewData["Title"] = "Schedule management";
}

<section class="admin-page" aria-label="Schedule management page">
    <div class="admin-page-header admin-page-header-inline">
        <div>
            <h1>Schedule management</h1>
            <p class="admin-page-subtitle">Create and manage schedules for academic groups</p>
        </div>
        <a asp-action="ScheduleCreate" class="admin-btn admin-btn-primary">Create schedule</a>
    </div>

    <div class="admin-schedule-grid">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title text-primary">Group: @item.Group.Name</h5>
                        <p class="card-text text-muted">
                            Last updated: @item.UpdateAt.ToString("dd.MM.yyyy HH:mm")
                        </p>
                        <ul class="list-unstyled small">
                            <li><i class="bi bi-check2-circle text-success"></i> Lessons in database: @item.Lessons.Count</li>
                            <li><i class="bi bi-shield-lock"></i> Headman rights: @(item.HeadmanUpdate ? "Yes" : "No")</li>
                        </ul>
                    </div>
                    <div class="card-footer bg-transparent border-top-0 d-flex justify-content-between">
                        <a asp-action="ScheduleEdit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Configure</a>
                        <a asp-action="ScheduleDetails" asp-route-id="@item.Id" class="btn btn-sm btn-info">View</a>
                        <a asp-action="ScheduleDelete" asp-route-id="@item.Id" class="btn btn-sm btn-info">Delete</a>
                        <form asp-action="ScheduleDelete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Delete this group schedule?')">
                            <button type="submit" class="btn btn-sm btn-link text-danger p-0"><i class="bi bi-trash"></i></button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</section>