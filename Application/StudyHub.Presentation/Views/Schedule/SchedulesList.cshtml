@model IEnumerable<StudyHub.Core.DTOs.ScheduleDto>

@{
    Layout = "_Layout";
    ViewData["Title"] = "Schedule management";
}

<section class="admin-page" aria-label="Schedule management page">
    <div class="admin-page-header admin-page-header-inline">
        <div>
            <h1>Schedule management</h1>
            <p class="admin-page-subtitle">Create and manage schedules for academic groups</p>
        </div>
        <a asp-action="ScheduleCreate" class="admin-btn admin-btn-primary">Create schedule</a>
    </div>

    <div class="admin-schedule-grid">
        @foreach (var item in Model)
        {
            <article class="admin-panel admin-schedule-card">
                <header class="admin-schedule-card-head">
                    <h2>@item.Group.Name</h2>
                    <p>Updated at @item.UpdateAt.ToString("dd.MM.yyyy HH:mm")</p>
                </header>

                <dl class="admin-meta-list">
                    <div><dt>Lessons</dt><dd>@item.Lessons.Count</dd></div>
                    <div><dt>Headman edit access</dt><dd>@(item.HeadmanUpdate ? "Enabled" : "Disabled")</dd></div>
                    <div><dt>Auto update</dt><dd>@(item.IsAutoUpdate ? "Enabled" : "Disabled")</dd></div>
                </dl>

                <footer class="admin-actions-inline">
                    <a asp-action="ScheduleEdit" asp-route-id="@item.Id" class="admin-link-btn">Edit</a>
                    <a asp-action="ScheduleDetails" asp-route-id="@item.Id" class="admin-link-btn">View</a>
                    <form asp-action="ScheduleDelete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Delete this schedule?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="admin-link-btn admin-link-btn-danger">Delete</button>
                    </form>
                </footer>
            </article>
        }
    </div>
</section>