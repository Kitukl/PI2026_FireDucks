@model StudyHub.Core.DTOs.ScheduleDto

@{
    Layout = "_Layout";
    ViewData["Title"] = "Create schedule";
}

<section class="admin-page" aria-label="Create schedule page">
    <div class="admin-page-header">
        <div>
            <h1>Create schedule</h1>
            <p class="admin-page-subtitle">Configure schedule settings before adding lessons</p>
        </div>
    </div>

    <form asp-action="ScheduleCreate" method="post" class="admin-panel admin-form-stack">
        <div>
            <label class="admin-label" for="groupSelect">Group</label>

            @if (ViewBag.Groups != null && ((IEnumerable<SelectListItem>)ViewBag.Groups).Any())
            {
                <select asp-for="Group.Id" class="admin-input" asp-items="ViewBag.Groups" id="groupSelect">
                    <option value="">Select group</option>
                </select>
                <input type="hidden" asp-for="Group.Name" id="groupNameHidden" value="TemporaryName" />
            }
            else
            {
                <div class="admin-alert admin-alert-error">
                    No groups found. <a asp-controller="Group" asp-action="Create">Create group</a> first.
                </div>
            }
            <span asp-validation-for="Group.Id" class="text-danger"></span>
        </div>

        <div class="admin-switch-grid">
            <label class="admin-switch-item">
                <input asp-for="LeaderUpdate" type="checkbox" />
                <span>Allow leader editing</span>
            </label>
            <label class="admin-switch-item">
                <input asp-for="IsAutoUpdate" type="checkbox" />
                <span>Auto update</span>
            </label>
        </div>

        <div asp-validation-summary="All" class="text-danger small"></div>

        <div class="admin-actions-inline">
            <button type="submit" class="admin-btn admin-btn-primary">Save schedule</button>
            <a asp-action="SchedulesList" class="admin-btn">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <script>
        $("#groupSelect").change(function () {
            const selectedText = $(this).find("option:selected").text();
            $("#groupNameHidden").val(selectedText);
        });
    </script>
}