@model Application.Models.ScheduleViewModel

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0 fw-bold">Розклад занять</h2>
            <p class="text-muted mb-0">Група: <strong>@Model.GroupName</strong></p>
        </div>

        @if (Model.IsHeadman && Model.CanHeadmanUpdate)
        {
            <form asp-action="SyncMySchedule" method="post">
                <input type="hidden" name="groupName" value="@Model.GroupName" />
                <button type="submit" class="btn btn-dark shadow-sm d-flex align-items-center gap-2" id="syncBtn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-clockwise" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z" />
                        <path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466" />
                    </svg>
                    Оновити розклад групи
                </button>
            </form>
        }
    </div>

    @if (Model.UniqueSlots == null || !Model.UniqueSlots.Any())
    {
        <div class="card border-0 shadow-sm text-center py-5">
            <div class="card-body">
                <img src="~/images/empty_schedule.svg" style="width: 150px; opacity: 0.5" class="mb-3" />
                <h4 class="text-muted">Розклад поки що порожній</h4>
                <p class="text-muted small">Зверніться до старости або зачекайте на оновлення від адміністрації.</p>
            </div>
        </div>
    }
    else
    {
        @await Html.PartialAsync("_ScheduleGridPartial", Model)
    }
</div>

@section Scripts {
    <script>
        $('#syncBtn').click(function() {
            $(this).prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Синхронізація...');
            $(this).closest('form').submit();
        });
    </script>
}