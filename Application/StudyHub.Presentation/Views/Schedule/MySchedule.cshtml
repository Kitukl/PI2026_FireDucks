@model Application.Models.ScheduleViewModel

<div class="taskboard-page container-fluid mt-4">
    <div class="p-3">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="mb-0 fw-bold">Group schedule</h2>
                <p class="text-muted mb-0">Group: <strong>@Model.GroupName</strong></p>
            </div>

            @if (Model.IsLeader && Model.CanLeaderUpdate)
            {
                <form asp-action="SyncMySchedule" method="post">
                    <input type="hidden" name="groupName" value="@Model.GroupName" />
                    <button type="submit" class="btn btn-dark shadow-sm d-flex align-items-center gap-2" id="syncBtn">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-clockwise" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M8 3a5 5 0 1 0 4.546 2.914.5.5 0 0 1 .908-.417A6 6 0 1 1 8 2z" />
                            <path d="M8 4.466V.534a.25.25 0 0 1 .41-.192l2.36 1.966c.12.1.12.284 0 .384L8.41 4.658A.25.25 0 0 1 8 4.466" />
                        </svg>
                        Update group schedule
                    </button>
                </form>
            }
        </div>

        @if (Model.UniqueSlots == null || !Model.UniqueSlots.Any())
        {
            <div class="card border-0 shadow-sm text-center py-5">
                <div class="card-body">
                    <h4 class="text-muted">Schedule is currently empty</h4>
                    <p class="text-muted small">Contact your leader or wait for an update from the administration.</p>
                </div>
            </div>
        }
        else
        {
            @await Html.PartialAsync("_ScheduleGridPartial", Model)
        }
    </div>
</div>

@section Scripts {
    <script>
        $('#syncBtn').click(function() {
            $(this).prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Syncing...');
            $(this).closest('form').submit();
        });
    </script>
}