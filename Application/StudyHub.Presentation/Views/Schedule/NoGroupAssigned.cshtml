@{
    ViewData["Title"] = "No group assigned";
}

<section class="admin-page" aria-label="No group assigned page">
    <div class="admin-page-header">
        <h1>No group assigned</h1>
        <p class="admin-page-subtitle">You currently do not have an academic group assigned.</p>
    </div>

    <article class="admin-panel" style="max-width: 760px; margin: 0 auto; padding: 28px 24px; text-align: center;">
        <div style="font-size: 3.25rem; line-height: 1; color: #6f7c8f; margin-bottom: 12px; text-align: center;">
            <i class="bi bi-people"></i>
        </div>

        <h2 style="margin-bottom: 8px;">Access to schedule is limited</h2>
        <p class="admin-page-subtitle" style="max-width: 640px; margin: 0 auto 18px; text-align: center;">
            Please contact your Leader to add you to an academic group.
            You can also contact StudyHub administrators if you need help with group assignment.
        </p>

        <div class="admin-actions-inline" style="justify-content: center;">
            <a asp-controller="User" asp-action="UserProfile" class="admin-btn admin-btn-primary">
                Contact admins
            </a>
            <a asp-controller="Dashboard" asp-action="Index" class="admin-btn">
                Back to dashboard
            </a>
        </div>
    </article>
</section>