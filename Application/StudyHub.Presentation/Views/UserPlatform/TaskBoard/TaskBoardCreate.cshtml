@model Application.Models.TaskBoardCreatePageViewModel
@using StudyHub.Domain.Enums
@{
    ViewData["Title"] = "Create task";
    var board = Model.Board;
    var maxDueDate = DateTime.Today.AddYears(5).ToString("yyyy-MM-dd");
    var toDoTasks = board.Tasks.Where(task => task.Status == Status.ToDo).ToList();
    var inProgressTasks = board.Tasks.Where(task => task.Status == Status.InProgress).ToList();
    var forReviewTasks = board.Tasks.Where(task => task.Status == Status.ForReview).ToList();
    var doneTasks = board.Tasks.Where(task => task.Status is Status.Done or Status.Resolved).ToList();

    string StatusDataValue(Status status) => status switch
    {
        Status.ToDo => "todo",
        Status.InProgress => "in-progress",
        Status.ForReview => "for-review",
        _ => "done"
    };
}

<section class="taskboard-page taskboard-create-page">
    <div class="taskboard-toolbar">
        <label class="taskboard-search" for="task-search-create">
            <span class="taskboard-search-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                    <path d="M10.5 3a7.5 7.5 0 0 1 5.96 12.06l4.24 4.24-1.42 1.42-4.24-4.24A7.5 7.5 0 1 1 10.5 3zm0 2a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11z"></path>
                </svg>
            </span>
            <input id="task-search-create" type="search" placeholder="Search" aria-label="Search tasks" />
        </label>

        <div class="taskboard-filter-control js-task-filter-control">
            <button class="taskboard-filter-btn js-task-filter-toggle" type="button" aria-expanded="false">
                <span class="taskboard-filter-icon">&#9776;</span>
                Filter by
            </button>

            <div class="taskboard-filter-dropdown" hidden>
                <button class="taskboard-filter-all js-task-filter-all" type="button">Unselect all</button>
                @foreach (var subject in board.Subjects)
                {
                    <label class="taskboard-filter-option"><input class="js-task-filter-checkbox" type="checkbox" value="@subject" checked />@subject</label>
                }
            </div>
        </div>

        <a class="taskboard-create-btn" asp-area="" asp-controller="TaskBoard" asp-action="TaskBoardCreate">Create task</a>
    </div>

    <div class="taskboard-grid">
        <aside class="taskboard-sidebar">
            <div class="taskboard-sidebar-group">
                <div class="taskboard-sidebar-title">Own tasks <button class="taskboard-radio js-task-scope-filter" type="button" data-scope="own" aria-label="Show own tasks"></button></div>
                <ul>
                    <li><span>To do</span><strong>@board.CountTasks(false, Status.ToDo)</strong></li>
                    <li><span>In progress</span><strong>@board.CountTasks(false, Status.InProgress)</strong></li>
                    <li><span>For review</span><strong>@board.CountTasks(false, Status.ForReview)</strong></li>
                    <li><span>Done</span><strong>@(board.CountTasks(false, Status.Done) + board.CountTasks(false, Status.Resolved))</strong></li>
                </ul>
            </div>

            <div class="taskboard-sidebar-group">
                <div class="taskboard-sidebar-title">Group tasks <button class="taskboard-radio js-task-scope-filter" type="button" data-scope="group" aria-label="Show group tasks"></button></div>
                <ul>
                    <li><span>To do</span><strong>@board.CountTasks(true, Status.ToDo)</strong></li>
                    <li><span>In progress</span><strong>@board.CountTasks(true, Status.InProgress)</strong></li>
                    <li><span>For review</span><strong>@board.CountTasks(true, Status.ForReview)</strong></li>
                    <li><span>Done</span><strong>@(board.CountTasks(true, Status.Done) + board.CountTasks(true, Status.Resolved))</strong></li>
                </ul>
            </div>

            <div class="taskboard-sidebar-group">
                <div class="taskboard-sidebar-title">All tasks <button class="taskboard-radio js-task-scope-filter active" type="button" data-scope="all" aria-label="Show all tasks"></button></div>
                <ul>
                    <li><span>To do</span><strong>@board.CountTasks(Status.ToDo)</strong></li>
                    <li><span>In progress</span><strong>@board.CountTasks(Status.InProgress)</strong></li>
                    <li><span>For review</span><strong>@board.CountTasks(Status.ForReview)</strong></li>
                    <li><span>Done</span><strong>@(board.CountTasks(Status.Done) + board.CountTasks(Status.Resolved))</strong></li>
                </ul>
            </div>

            @if (User.IsInRole("Leader"))
            {
                <a class="taskboard-manage-btn" asp-area="" asp-controller="TaskBoard" asp-action="TaskBoardReviewGroup">Manage group</a>
            }
        </aside>

        <div class="taskboard-columns-scroll">
            <section class="taskboard-column" data-column-status="todo">
                <h2>To do</h2>
                @foreach (var task in toDoTasks)
                {
                    <article class="task-card" data-status="@StatusDataValue(task.Status)" data-task-id="@task.Id" data-deadline="@task.Deadline.ToString("yyyy-MM-dd")">
                        <header>
                            <h3 title="@task.Title">@task.Title</h3>
                            <span class="task-card-status"></span>
                        </header>
                        <p class="task-card-subject" data-subject="@task.SubjectName" title="@task.SubjectName">@task.SubjectName</p>
                        <div class="task-card-meta">
                            @if (task.IsGroupTask)
                            {
                                <span class="task-group-label"><span class="task-group-icon" aria-hidden="true"><svg viewBox="0 0 24 24" focusable="false" aria-hidden="true"><path d="M9 11a3 3 0 1 0-3-3 3 3 0 0 0 3 3zm6 0a3 3 0 1 0-3-3 3 3 0 0 0 3 3zM5 18v-1a3 3 0 0 1 3-3h2a3 3 0 0 1 3 3v1m-2 0v-1a3 3 0 0 1 3-3h2a3 3 0 0 1 3 3v1"></path></svg></span><span>Group task</span></span>
                            }
                            else
                            {
                                <span></span>
                            }

                            <span class="task-card-badge" title="@task.OwnerName">
                                @if (!string.IsNullOrWhiteSpace(task.OwnerPhotoUrl))
                                {
                                    <img class="task-card-avatar" src="@task.OwnerPhotoUrl" alt="@task.OwnerName" loading="lazy" />
                                }
                                else
                                {
                                    <span class="task-card-badge-fallback">@(task.IsGroupTask ? "👤" : "👩‍💼")</span>
                                }
                            </span>
                        </div>
                        <footer><a class="task-card-link" asp-area="" asp-controller="TaskBoard" asp-action="TaskBoardViewTask" asp-route-taskCode="@task.Id">@task.TaskCode</a></footer>
                    </article>
                }
            </section>

            <section class="taskboard-column" data-column-status="in-progress">
                <h2>In progress</h2>
                @foreach (var task in inProgressTasks)
                {
                    <article class="task-card" data-status="@StatusDataValue(task.Status)" data-task-id="@task.Id" data-deadline="@task.Deadline.ToString("yyyy-MM-dd")">
                        <header>
                            <h3 title="@task.Title">@task.Title</h3>
                            <span class="task-card-status"></span>
                        </header>
                        <p class="task-card-subject" data-subject="@task.SubjectName" title="@task.SubjectName">@task.SubjectName</p>
                        <div class="task-card-meta">
                            @if (task.IsGroupTask)
                            {
                                <span class="task-group-label"><span class="task-group-icon" aria-hidden="true"><svg viewBox="0 0 24 24" focusable="false" aria-hidden="true"><path d="M9 11a3 3 0 1 0-3-3 3 3 0 0 0 3 3zm6 0a3 3 0 1 0-3-3 3 3 0 0 0 3 3zM5 18v-1a3 3 0 0 1 3-3h2a3 3 0 0 1 3 3v1m-2 0v-1a3 3 0 0 1 3-3h2a3 3 0 0 1 3 3v1"></path></svg></span><span>Group task</span></span>
                            }
                            else
                            {
                                <span></span>
                            }

                            <span class="task-card-badge" title="@task.OwnerName">
                                @if (!string.IsNullOrWhiteSpace(task.OwnerPhotoUrl))
                                {
                                    <img class="task-card-avatar" src="@task.OwnerPhotoUrl" alt="@task.OwnerName" loading="lazy" />
                                }
                                else
                                {
                                    <span class="task-card-badge-fallback">@(task.IsGroupTask ? "👤" : "👩‍💼")</span>
                                }
                            </span>
                        </div>
                        <footer><a class="task-card-link" asp-area="" asp-controller="TaskBoard" asp-action="TaskBoardViewTask" asp-route-taskCode="@task.Id">@task.TaskCode</a></footer>
                    </article>
                }
            </section>

            <section class="taskboard-column" data-column-status="for-review">
                <h2>For review</h2>
                @foreach (var task in forReviewTasks)
                {
                    <article class="task-card" data-status="@StatusDataValue(task.Status)" data-task-id="@task.Id" data-deadline="@task.Deadline.ToString("yyyy-MM-dd")">
                        <header>
                            <h3 title="@task.Title">@task.Title</h3>
                            <span class="task-card-status"></span>
                        </header>
                        <p class="task-card-subject" data-subject="@task.SubjectName" title="@task.SubjectName">@task.SubjectName</p>
                        <div class="task-card-meta">
                            @if (task.IsGroupTask)
                            {
                                <span class="task-group-label"><span class="task-group-icon" aria-hidden="true"><svg viewBox="0 0 24 24" focusable="false" aria-hidden="true"><path d="M9 11a3 3 0 1 0-3-3 3 3 0 0 0 3 3zm6 0a3 3 0 1 0-3-3 3 3 0 0 0 3 3zM5 18v-1a3 3 0 0 1 3-3h2a3 3 0 0 1 3 3v1m-2 0v-1a3 3 0 0 1 3-3h2a3 3 0 0 1 3 3v1"></path></svg></span><span>Group task</span></span>
                            }
                            else
                            {
                                <span></span>
                            }

                            <span class="task-card-badge" title="@task.OwnerName">
                                @if (!string.IsNullOrWhiteSpace(task.OwnerPhotoUrl))
                                {
                                    <img class="task-card-avatar" src="@task.OwnerPhotoUrl" alt="@task.OwnerName" loading="lazy" />
                                }
                                else
                                {
                                    <span class="task-card-badge-fallback">@(task.IsGroupTask ? "👤" : "👩‍💼")</span>
                                }
                            </span>
                        </div>
                        <footer><a class="task-card-link" asp-area="" asp-controller="TaskBoard" asp-action="TaskBoardViewTask" asp-route-taskCode="@task.Id">@task.TaskCode</a></footer>
                    </article>
                }
            </section>

            <section class="taskboard-column" data-column-status="done">
                <h2>Done</h2>
                @foreach (var task in doneTasks)
                {
                    <article class="task-card" data-status="done" data-task-id="@task.Id" data-deadline="@task.Deadline.ToString("yyyy-MM-dd")" data-completed-at="@DateTime.UtcNow.ToString("yyyy-MM-dd")">
                        <header>
                            <h3 title="@task.Title">@task.Title</h3>
                            <span class="task-card-state">&#10003;</span>
                        </header>
                        <p class="task-card-subject" data-subject="@task.SubjectName" title="@task.SubjectName">@task.SubjectName</p>
                        <div class="task-card-meta">
                            @if (task.IsGroupTask)
                            {
                                <span class="task-group-label"><span class="task-group-icon" aria-hidden="true"><svg viewBox="0 0 24 24" focusable="false" aria-hidden="true"><path d="M9 11a3 3 0 1 0-3-3 3 3 0 0 0 3 3zm6 0a3 3 0 1 0-3-3 3 3 0 0 0 3 3zM5 18v-1a3 3 0 0 1 3-3h2a3 3 0 0 1 3 3v1m-2 0v-1a3 3 0 0 1 3-3h2a3 3 0 0 1 3 3v1"></path></svg></span><span>Group task</span></span>
                            }
                            else
                            {
                                <span></span>
                            }

                            <span class="task-card-badge" title="@task.OwnerName">
                                @if (!string.IsNullOrWhiteSpace(task.OwnerPhotoUrl))
                                {
                                    <img class="task-card-avatar" src="@task.OwnerPhotoUrl" alt="@task.OwnerName" loading="lazy" />
                                }
                                else
                                {
                                    <span class="task-card-badge-fallback">@(task.IsGroupTask ? "👤" : "👩‍💼")</span>
                                }
                            </span>
                        </div>
                        <footer><a class="task-card-link" asp-area="" asp-controller="TaskBoard" asp-action="TaskBoardViewTask" asp-route-taskCode="@task.Id">@task.TaskCode</a></footer>
                    </article>
                }
            </section>
        </div>
    </div>

    <div class="task-modal-backdrop" aria-hidden="true"></div>

    <section class="task-create-modal" role="dialog" aria-modal="true" aria-label="Create task">
        <form class="task-create-form" asp-controller="TaskBoard" asp-action="TaskBoardCreate" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="task-create-top">
                <label class="visually-hidden" asp-for="Title">Task name</label>
                <input asp-for="Title" id="task-title" class="task-create-name-input" type="text" placeholder="Name your task..." maxlength="200" />
                <a class="task-create-cancel" asp-area="" asp-controller="TaskBoard" asp-action="TaskBoard">Cancel</a>
            </div>
            <span asp-validation-for="Title" class="text-danger"></span>

            <div class="task-create-fieldset">
                <h2>Description</h2>
                <div class="task-view-editor js-rich-editor task-create-description-editor">
                    <div class="task-view-editor-head">
                        <div class="task-view-editor-tools" aria-label="Description formatting">
                            <button class="task-view-tool-btn js-rich-format-btn" type="button" data-command="bold" aria-label="Bold">B</button>
                            <button class="task-view-tool-btn js-rich-format-btn" type="button" data-command="italic" aria-label="Italic"><em>I</em></button>
                            <button class="task-view-tool-btn js-rich-format-btn" type="button" data-command="underline" aria-label="Underline"><u>U</u></button>
                            <button class="task-view-tool-btn js-rich-format-btn" type="button" data-command="strikeThrough" aria-label="Strike through"><s>S</s></button>
                        </div>
                    </div>
                    <div class="task-view-comment-input js-rich-editor-input" contenteditable="true" role="textbox" aria-multiline="true" data-placeholder="Describe what needs to be done..." data-max-chars="200">@Model.Description</div>
                    <textarea class="visually-hidden js-rich-editor-hidden" asp-for="Description"></textarea>
                    <div class="task-summary-counter js-rich-char-counter" aria-live="polite">0/200</div>
                </div>
            </div>

            <div class="task-create-fieldset task-create-details">
                <h2>Details</h2>
                <div class="task-create-row">
                    <label class="task-create-inline-field" asp-for="SubjectId">
                        <span>Subject:</span>
                        <select asp-for="SubjectId">
                            <option value="">Select subject</option>
                            @foreach (var subject in Model.Subjects)
                            {
                                <option value="@subject.Id" title="@subject.Name">@(string.IsNullOrWhiteSpace(subject.DisplayName) ? subject.Name : subject.DisplayName)</option>
                            }
                        </select>
                    </label>
                    <span asp-validation-for="SubjectId" class="text-danger"></span>

                    <label class="task-create-inline-field task-create-date-field" asp-for="DueDate">
                        <span>Due date:</span>
                        <input asp-for="DueDate" type="date" max="@maxDueDate" />
                    </label>

                    <label class="task-create-inline-field" asp-for="ResourceUrl">
                        <span>Resource URL:</span>
                        <input asp-for="ResourceUrl" type="url" placeholder="https://..." />
                    </label>

                    <label class="task-create-checkbox" asp-for="IsGroupTask">
                        <input asp-for="IsGroupTask" type="checkbox" />
                        <span class="task-create-group-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                <path d="M9 11a3 3 0 1 0-3-3 3 3 0 0 0 3 3zm6 0a3 3 0 1 0-3-3 3 3 0 0 0 3 3zM5 18v-1a3 3 0 0 1 3-3h2a3 3 0 0 1 3 3v1m-2 0v-1a3 3 0 0 1 3-3h2a3 3 0 0 1 3 3v1"></path>
                            </svg>
                        </span>
                        <span>Group task</span>
                    </label>
                </div>
            </div>

            <div class="task-create-actions">
                <button type="submit" class="task-create-submit">Create task</button>
            </div>
        </form>
    </section>
</section>
