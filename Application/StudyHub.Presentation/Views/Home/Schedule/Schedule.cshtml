@{
    ViewData["Title"] = "Schedule";
}

<style>
    .schedule-user-page {
        border: 1px solid rgba(18, 24, 38, 0.35);
        border-radius: 16px;
        background: #ffffff;
        overflow: hidden;
    }

    .schedule-user-table-wrap {
        overflow-x: auto;
    }

    .schedule-user-table {
        width: 100%;
        min-width: 1040px;
        border-collapse: collapse;
        table-layout: fixed;
    }

    .schedule-user-table th,
    .schedule-user-table td {
        border: 1px solid #aeb7c2;
        vertical-align: top;
        background: #ffffff;
    }

    .schedule-user-table thead th {
        height: 62px;
        text-align: center;
        font-family: 'Bebas Neue', 'Archivo', 'Trebuchet MS', sans-serif;
        letter-spacing: 0.03em;
        font-size: 1.62rem;
        color: #1f2a38;
        background: #ffffff;
    }

    .schedule-user-time-head {
        width: 150px;
        background: #ffffff;
    }

    .schedule-user-time {
        width: 150px;
        font-size: 1.6rem;
        font-family: 'Bebas Neue', 'Archivo', 'Trebuchet MS', sans-serif;
        color: #2d3644;
        text-align: center;
        vertical-align: middle;
        letter-spacing: 0.02em;
        background: #ffffff;
    }

    .schedule-user-slot {
        height: 168px;
        padding: 6px;
    }

    .schedule-user-slot--double {
        display: flex;
        flex-direction: column;
        gap: 6px;
        overflow: hidden;
        height: 282px;
    }

    .schedule-card {
        border: 2px solid #b7c0cb;
        border-radius: 12px;
        background: #ffffff;
        height: 100%;
        padding: 9px 10px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        overflow: hidden;
    }

    .schedule-card--half {
        height: calc((100% - 6px) / 2);
        min-height: 0;
        padding: 7px 8px;
        gap: 6px;
        justify-content: space-between;
    }

    .schedule-card-head {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        flex: 0 0 auto;
    }

    .schedule-type-badge {
        min-width: 26px;
        height: 26px;
        border-radius: 10px;
        background: #091321;
        color: #fff;
        font-family: 'Manrope', 'Segoe UI', sans-serif;
        font-weight: 800;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.95rem;
    }

    .schedule-subject {
        text-align: center;
        font-family: 'Manrope', 'Segoe UI', sans-serif;
        letter-spacing: 0.01em;
        color: #101929;
        font-size: 1.16rem;
        line-height: 1.16;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        flex: 1 1 auto;
        min-height: 0;
        margin-top: 0;
        overflow: hidden;
        white-space: normal;
        word-break: break-word;
    }

    .schedule-card--half .schedule-subject {
        font-size: 0.84rem;
        margin-top: 0;
        line-height: 1.12;
        display: flex;
        align-items: center;
        justify-content: center;
        flex: 1 1 auto;
        white-space: normal;
        overflow: visible;
        text-align: center;
        font-weight: 700;
        word-break: break-word;
    }

    .schedule-subject--long {
        font-size: inherit;
        line-height: inherit;
    }

    .schedule-card--half .schedule-subject--long {
        font-size: inherit;
        line-height: inherit;
    }

    .schedule-card-foot {
        margin-top: auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        font-size: 1.02rem;
        line-height: 1;
        min-height: 20px;
        flex: 0 0 auto;
    }

    .schedule-card--half .schedule-card-foot {
        margin-top: 0;
        font-size: 0.78rem;
        gap: 4px;
        flex: 0 0 auto;
        line-height: 1;
        min-height: 14px;
    }

    .schedule-room {
        color: #1f2c3a;
        font-weight: 500;
    }

    .schedule-teachers {
        color: #334052;
        font-style: italic;
        text-align: right;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 56%;
    }

    .schedule-card--half .schedule-teachers {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 52%;
    }

    .schedule-card--half .schedule-room {
        white-space: nowrap;
    }

    .schedule-empty {
        background: #ffffff;
    }

    @@media (max-width: 1200px) {
        .schedule-user-table {
            min-width: 920px;
        }

        .schedule-user-table thead th {
            font-size: 1.42rem;
        }

        .schedule-user-time {
            font-size: 1.35rem;
        }

        .schedule-subject {
            font-size: 1.02rem;
        }

        .schedule-card-foot {
            font-size: 0.92rem;
        }
    }
</style>

