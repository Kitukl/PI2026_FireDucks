@using System.Globalization
@using StudyHub.Domain.Entities
@{
    ViewData["Title"] = "User profile";
    const int feedbackSubjectMaxLength = 160;
    const int feedbackDescriptionMaxLength = 700;
    
    var fullName = (string?)ViewBag.FullName ?? "Гість";
    var photoUrl = (string?)ViewBag.PhotoUrl ?? Url.Content("~/images/no-photo.png");
    
    var feedbackTypes = Enum.GetValues<FeedbackType>();
    var categories = Enum.GetValues<Category>();
    var timeTypes = Enum.GetValues<TimeType>();
    var reminderOffsets = Enumerable.Range(1, 10);

    // ВАЖЛИВО: Отримуємо збережені значення з ViewBag
    bool isNotified = ViewBag.IsNotified ?? true;
    var currentOffset = ViewBag.ReminderOffset ?? 2;
    var currentTimeType = ViewBag.ReminderTimeType ?? TimeType.Day;
    var activityYear = DateTime.Now.Year;
    var activitySource = ViewBag.MonthlyActivityPerMonth as Dictionary<int, double> ?? new Dictionary<int, double>();
    var monthlyActivity = Enumerable.Range(1, 12)
        .Select(month =>
        {
            var value = activitySource.TryGetValue(month, out var monthValue) ? monthValue : 0d;
            return new
            {
                Label = CultureInfo.InvariantCulture.DateTimeFormat.GetAbbreviatedMonthName(month),
                Value = Math.Round(value, 2)
            };
        })
        .ToList();
    var maxMonthlyActivity = monthlyActivity.Max(item => item.Value);
    var activeMonthlyActivity = monthlyActivity.Where(item => item.Value > 0).ToList();
    var peakMonthLabel = activeMonthlyActivity.Count > 0
        ? activeMonthlyActivity.OrderByDescending(item => item.Value).First().Label
        : "No data";
    var activeMonthsAverage = activeMonthlyActivity.Count > 0
        ? activeMonthlyActivity.Average(item => item.Value)
        : 0d;

    string FormatActivityValue(double value)
    {
        return value.ToString("0.##", CultureInfo.InvariantCulture);
    }
}

<section class="user-profile-page">
    <div class="user-profile-grid">
        <section class="user-profile-left">
            @* Блок фото *@
            <div class="user-photo-card">
                <form asp-controller="User" asp-action="UploadProfilePhoto" method="post" enctype="multipart/form-data" class="js-profile-photo-form">
                    @Html.AntiForgeryToken()
                    <input id="profilePhotoInput" name="photoFile" type="file" accept="image/*" hidden class="js-profile-photo-input" />
                    <button type="button" class="user-photo-btn js-profile-photo-btn">Choose Profile Photo</button>
                    <div class="user-photo-actions js-profile-photo-actions" hidden>
                        <button type="submit" class="user-photo-confirm-btn js-profile-photo-confirm">Confirm</button>
                        <button type="button" class="user-photo-cancel-btn js-profile-photo-cancel">Cancel</button>
                    </div>
                </form>
                <div class="user-photo-frame">
                    <img src="@photoUrl" alt="Profile photo" class="js-profile-photo-image" data-original-src="@photoUrl" />
                </div>
            </div>

            <h1 class="user-profile-name">@fullName</h1>

            @* БЛОК НАЛАШТУВАНЬ З ВИПРАВЛЕНИМ SELECTED *@
            <fieldset class="user-settings-card js-user-settings" 
                      data-update-url="@Url.Action("UpdateReminderSettings", "User")">
                @Html.AntiForgeryToken()
                <legend>Settings</legend>

                <div class="user-settings-controls">
                    <button type="button" class="user-settings-icon is-muted js-user-settings-muted" title="Mute notifications">
                        <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                            <path d="M12 22a2.5 2.5 0 0 0 2.45-2h-4.9A2.5 2.5 0 0 0 12 22zM18 16v-5.5c0-2.9-1.6-5.35-4.5-6.04V3.5a1.5 1.5 0 1 0-3 0v.96C7.6 5.15 6 7.6 6 10.5V16l-2 2v1h16v-1l-2-2zM4 4.9 5.4 3.5 20.5 18.6 19.1 20z"></path>
                        </svg>
                    </button>

                    @* Тогл стає активним, якщо в базі true *@
                    <button type="button" class="user-settings-toggle js-user-settings-toggle @(isNotified ? "active" : "")" title="Notifications toggle">
                        <span class="user-settings-knob"></span>
                    </button>
                    <input class="js-user-settings-value" type="hidden" name="isNotified" value="@(isNotified ? "true" : "false")" />

                    <button type="button" class="user-settings-icon js-user-settings-bell" title="Enable reminders">
                        <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                            <path d="M12 22a2.5 2.5 0 0 0 2.45-2h-4.9A2.5 2.5 0 0 0 12 22zM18 16v-5.5c0-2.9-1.6-5.35-4.5-6.04V3.5a1.5 1.5 0 1 0-3 0v.96C7.6 5.15 6 7.6 6 10.5V16l-2 2v1h16v-1l-2-2z"></path>
                        </svg>
                    </button>
                </div>

                <label class="user-reminder-row">
                    <span>Send a reminder</span>
                    @* ПЕРЕВІРКА: Порівнюємо кожну опцію з currentOffset *@
                    <select class="js-user-reminder-offset js-reminder-auto-update">
                        @foreach (var offset in reminderOffsets)
                        {
                            <option value="@offset" selected="@(offset == (int)currentOffset ? "selected" : null)">@offset</option>
                        }
                    </select>
                    
                    @* ПЕРЕВІРКА: Порівнюємо кожну опцію з currentTimeType *@
                    <select class="js-user-reminder-type js-reminder-auto-update">
                        @foreach (var timeType in timeTypes)
                        {
                            <option value="@timeType" selected="@(timeType == currentTimeType ? "selected" : null)">@timeType</option>
                        }
                    </select>
                    <span>before due date</span>
                </label>
            </fieldset>
        </section>

        <section class="user-profile-right">
            @* Форма контактів *@
            <article class="user-contact-card">
                <header class="user-contact-head">
                    <h2>Contact form</h2>
                    <button type="button" class="user-contact-help">?</button>
                </header>

                @if (TempData["ProfileFeedbackSuccess"] is string successMessage)
                {
                    <p class="user-profile-form-success">@successMessage</p>
                }

                <form asp-controller="User" asp-action="UserProfileSendRequest" method="post">
                    @Html.AntiForgeryToken()

                    <label class="user-contact-row">
                        <span>Type:</span>
                        <select name="feedbackType">
                            @foreach (var type in feedbackTypes)
                            {
                                <option value="@type" selected="@(type == FeedbackType.Request ? "selected" : null)">@type</option>
                            }
                        </select>
                    </label>

                    <label class="user-contact-row">
                        <span>Category:</span>
                        <select name="category">
                            @foreach (var category in categories)
                            {
                                <option value="@category" selected="@(category == Category.Improvement ? "selected" : null)">@category</option>
                            }
                        </select>
                    </label>

                    <input class="user-contact-subject js-feedback-subject" name="subject" type="text" placeholder="Subject" maxlength="@feedbackSubjectMaxLength" />
                    
                    <div class="task-view-editor js-rich-editor user-contact-editor">
                        <div class="task-view-editor-head">
                            <div class="task-view-editor-tools">
                                <button class="task-view-tool-btn js-rich-format-btn" type="button" data-command="bold">B</button>
                                <button class="task-view-tool-btn js-rich-format-btn" type="button" data-command="italic">I</button>
                            </div>
                            <button class="task-view-comment-btn" type="submit">Send request</button>
                        </div>
                        <div class="task-view-comment-input js-rich-editor-input" contenteditable="true" data-placeholder="Please describe your problem..." data-max-chars="@feedbackDescriptionMaxLength"></div>
                        <textarea class="visually-hidden js-rich-editor-hidden" name="description"></textarea>
                    </div>
                </form>
            </article>
        </section>
    </div>

    <article class="profile-activity-panel user-contact-card">
        <header class="user-contact-head">
            <h2>Activity per month</h2>
        </header>

        <div class="profile-activity-layout">
            <section class="profile-activity-chart-shell" aria-label="Average day duration per month">
                <div class="profile-activity-chart-meta">
                    <h3>Average day duration</h3>
                    <p>@activityYear, minutes</p>
                </div>

                <div class="profile-activity-bars">
                    @foreach (var item in monthlyActivity)
                    {
                        var barHeight = maxMonthlyActivity > 0
                            ? Math.Max(4, Math.Round(item.Value / maxMonthlyActivity * 100, 2))
                            : 4;
                        var barClass = item.Value <= 0 ? "profile-activity-bar is-empty" : "profile-activity-bar";
                        var displayValue = item.Value > 0 ? FormatActivityValue(item.Value) : "-";

                        <div class="profile-activity-bar-group">
                            <div class="profile-activity-value">@displayValue</div>
                            <div class="profile-activity-bar-track">
                                <div class="@barClass" style="height: @($"{barHeight.ToString("0.##", CultureInfo.InvariantCulture)}%");"></div>
                            </div>
                            <div class="profile-activity-label">@item.Label</div>
                        </div>
                    }
                </div>
            </section>

            <aside class="profile-activity-summary">
                <h3>Highlights</h3>
                <ul>
                    <li><span>Peak month</span><strong>@peakMonthLabel</strong></li>
                    <li><span>Peak value</span><strong>@FormatActivityValue(maxMonthlyActivity) min</strong></li>
                    <li><span>Active months average</span><strong>@FormatActivityValue(activeMonthsAverage) min</strong></li>
                </ul>
            </aside>
        </div>
    </article>
</section>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const settingsBlock = document.querySelector('.js-user-settings');
            if (!settingsBlock) return;

            const toggleBtn = settingsBlock.querySelector('.js-user-settings-toggle');
            const hiddenInput = settingsBlock.querySelector('.js-user-settings-value');
            const selects = settingsBlock.querySelectorAll('.js-reminder-auto-update');
            const token = settingsBlock.querySelector('input[name="__RequestVerificationToken"]').value;

            async function saveSettings() {
                const url = settingsBlock.dataset.updateUrl;
                const data = new URLSearchParams();
                
                data.append("isNotified", hiddenInput.value);
                data.append("offset", settingsBlock.querySelector('.js-user-reminder-offset').value);
                data.append("timeType", settingsBlock.querySelector('.js-user-reminder-type').value);
                data.append("__RequestVerificationToken", token);

                settingsBlock.style.opacity = "0.5";

                try {
                    const response = await fetch(url, {
                        method: "POST",
                        headers: { "Content-Type": "application/x-www-form-urlencoded", "X-Requested-With": "XMLHttpRequest" },
                        body: data
                    });
                    if (response.ok) console.log("Налаштування збережено");
                } catch (e) {
                    console.error("Помилка збереження", e);
                } finally {
                    settingsBlock.style.opacity = "1";
                }
            }

            toggleBtn.addEventListener('click', function() {
                const isActive = this.classList.toggle('active');
                hiddenInput.value = isActive ? "true" : "false";
                saveSettings();
            });

            selects.forEach(s => s.addEventListener('change', saveSettings));
        });
    </script>
}
