@{
    ViewData["Title"] = "View task";
    var taskCode = ViewBag.TaskCode?.ToString() ?? "A-3";
    var dueDate = DateTime.Today.AddDays(1);
    var rawUserName = User.Identity?.Name ?? "guest";
    var currentUserName = rawUserName.Contains("\\", StringComparison.Ordinal)
        ? rawUserName.Split('\\').Last()
        : rawUserName.Split('@')[0];
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "user-guest";
    var currentUserFirstName = currentUserName
        .Split(new[] { '.', '_', '-', ' ' }, StringSplitOptions.RemoveEmptyEntries)
        .FirstOrDefault() ?? currentUserName;
    var commentAuthorName = "Marta";
    var commentAuthorId = "user-marta";
    var secondCommentAuthorUserId = currentUserId;
    var secondCommentAuthorName = currentUserFirstName;
    var taskOwnerId = "user-task-owner";
    var isGroupTask = true;
    var canDeleteComment =
        string.Equals(currentUserId, commentAuthorId, StringComparison.Ordinal) ||
        string.Equals(currentUserId, taskOwnerId, StringComparison.Ordinal) ||
        (isGroupTask && User.IsInRole("Leader"));
    var canDeleteSecondComment =
        string.Equals(currentUserId, secondCommentAuthorUserId, StringComparison.Ordinal) ||
        string.Equals(currentUserId, taskOwnerId, StringComparison.Ordinal) ||
        (isGroupTask && User.IsInRole("Leader"));
}

<section class="taskboard-page taskboard-view-page">
    <div class="taskboard-toolbar">
        <label class="taskboard-search" for="task-search-view">
            <span class="taskboard-search-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                    <path d="M10.5 3a7.5 7.5 0 0 1 5.96 12.06l4.24 4.24-1.42 1.42-4.24-4.24A7.5 7.5 0 1 1 10.5 3zm0 2a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11z"></path>
                </svg>
            </span>
            <input id="task-search-view" type="search" placeholder="Search" aria-label="Search tasks" />
        </label>

        <div class="taskboard-filter-control js-task-filter-control">
            <button class="taskboard-filter-btn js-task-filter-toggle" type="button" aria-expanded="false">
                <span class="taskboard-filter-icon">&#9776;</span>
                Filter by
            </button>

            <div class="taskboard-filter-dropdown" hidden>
                <button class="taskboard-filter-all js-task-filter-all" type="button">Unselect all</button>
                <label class="taskboard-filter-option"><input class="js-task-filter-checkbox" type="checkbox" value="Subject#A" checked />Subject#A</label>
                <label class="taskboard-filter-option"><input class="js-task-filter-checkbox" type="checkbox" value="Subject#B" checked />Subject#B</label>
                <label class="taskboard-filter-option"><input class="js-task-filter-checkbox" type="checkbox" value="Subject#C" checked />Subject#C</label>
                <label class="taskboard-filter-option"><input class="js-task-filter-checkbox" type="checkbox" value="Subject#D" checked />Subject#D</label>
                <label class="taskboard-filter-option"><input class="js-task-filter-checkbox" type="checkbox" value="Subject#E" checked />Subject#E</label>
                <label class="taskboard-filter-option"><input class="js-task-filter-checkbox" type="checkbox" value="Subject#F" checked />Subject#F</label>
                <label class="taskboard-filter-option"><input class="js-task-filter-checkbox" type="checkbox" value="Subject#G" checked />Subject#G</label>
            </div>
        </div>

        <a class="taskboard-create-btn" asp-area="" asp-controller="Home" asp-action="TaskBoardCreate">Create task</a>
    </div>

    <div class="taskboard-grid">
        <aside class="taskboard-sidebar">
            <div class="taskboard-sidebar-group">
                <div class="taskboard-sidebar-title">Own tasks <button class="taskboard-radio js-task-scope-filter" type="button" data-scope="own" aria-label="Show own tasks"></button></div>
                <ul>
                    <li><span>To do</span><strong>0</strong></li>
                    <li><span>In progress</span><strong>1</strong></li>
                    <li><span>For review</span><strong>2</strong></li>
                    <li><span>Done</span><strong>1</strong></li>
                </ul>
            </div>

            <div class="taskboard-sidebar-group">
                <div class="taskboard-sidebar-title">Group tasks <button class="taskboard-radio js-task-scope-filter" type="button" data-scope="group" aria-label="Show group tasks"></button></div>
                <ul>
                    <li><span>To do</span><strong>1</strong></li>
                    <li><span>In progress</span><strong>1</strong></li>
                    <li><span>For review</span><strong>1</strong></li>
                    <li><span>Done</span><strong>1</strong></li>
                </ul>
            </div>

            <div class="taskboard-sidebar-group">
                <div class="taskboard-sidebar-title">All tasks <button class="taskboard-radio js-task-scope-filter active" type="button" data-scope="all" aria-label="Show all tasks"></button></div>
                <ul>
                    <li><span>To do</span><strong>1</strong></li>
                    <li><span>In progress</span><strong>2</strong></li>
                    <li><span>For review</span><strong>3</strong></li>
                    <li><span>Done</span><strong>2</strong></li>
                </ul>
            </div>

            @if (User.IsInRole("Leader"))
            {
                <a class="taskboard-manage-btn" asp-area="" asp-controller="Home" asp-action="TaskBoardReviewGroup">Manage group</a>
            }
        </aside>

        <div class="taskboard-columns-scroll">
            <section class="taskboard-column">
                <h2>To do</h2>
                <article class="task-card">
                    <header>
                        <h3>New Task#7</h3>
                        <span class="task-card-status"></span>
                    </header>
                    <p>Subject#A</p>
                    <div class="task-card-meta">
                        <span class="task-group-label"><span class="task-group-icon" aria-hidden="true"><svg viewBox="0 0 24 24" focusable="false" aria-hidden="true"><path d="M9 11a3 3 0 1 0-3-3 3 3 0 0 0 3 3zm6 0a3 3 0 1 0-3-3 3 3 0 0 0 3 3zM5 18v-1a3 3 0 0 1 3-3h2a3 3 0 0 1 3 3v1m-2 0v-1a3 3 0 0 1 3-3h2a3 3 0 0 1 3 3v1"></path></svg></span><span>Group task</span></span>
                        <span class="task-card-badge">&#128100;</span>
                    </div>
                    <footer>@taskCode</footer>
                </article>
            </section>

            <section class="taskboard-column"><h2>In progress</h2></section>
            <section class="taskboard-column"><h2>For review</h2></section>
            <section class="taskboard-column"><h2>Done</h2></section>
        </div>
    </div>

    <div class="task-modal-backdrop" aria-hidden="true"></div>

    <section class="task-view-modal" role="dialog" aria-modal="true" aria-label="View task">
        <div class="task-view-shell">
            <div class="task-view-top">
                <h1>New task#7</h1>

                <div class="task-view-top-tools">
                    <span class="task-group-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                            <path d="M9 11a3 3 0 1 0-3-3 3 3 0 0 0 3 3zm6 0a3 3 0 1 0-3-3 3 3 0 0 0 3 3zM5 18v-1a3 3 0 0 1 3-3h2a3 3 0 0 1 3 3v1m-2 0v-1a3 3 0 0 1 3-3h2a3 3 0 0 1 3 3v1"></path>
                        </svg>
                    </span>
                    <span class="task-deadline-indicator js-task-view-deadline" data-deadline="@dueDate.ToString("yyyy-MM-dd")" data-status="todo" aria-hidden="true"></span>
                    <div class="task-view-status-dropdown js-status-dropdown">
                        <button type="button" class="task-view-status-btn js-status-dropdown-toggle" aria-haspopup="listbox" aria-expanded="false">To do</button>
                        <ul class="task-view-status-menu js-status-dropdown-menu" role="listbox" hidden>
                            <li><button type="button" class="task-view-status-option" data-value="todo">To do</button></li>
                            <li><button type="button" class="task-view-status-option" data-value="in-progress">In progress</button></li>
                            <li><button type="button" class="task-view-status-option" data-value="for-review">For review</button></li>
                            <li><button type="button" class="task-view-status-option" data-value="done">Done</button></li>
                        </ul>
                        <select class="task-view-status js-task-view-status visually-hidden" aria-label="Task status">
                            <option value="todo" selected>To do</option>
                            <option value="in-progress">In progress</option>
                            <option value="for-review">For review</option>
                            <option value="done">Done</option>
                        </select>
                    </div>
                    <a class="task-view-back" asp-area="" asp-controller="Home" asp-action="TaskBoard">&lt; Back to the board</a>
                </div>
            </div>

            <div class="task-view-main">
                <div class="task-view-description">
                    <h2>Description</h2>
                    <div class="task-view-textbox">Description of the task.</div>
                </div>

                <aside class="task-view-details">
                    <h2>Details</h2>
                    <dl>
                        <div><dt>Subject:</dt><dd>Subject#A</dd></div>
                        <div><dt>Due date:</dt><dd>@dueDate.ToString("dd.MM.yyyy")</dd></div>
                        <div><dt>Task:</dt><dd>@taskCode</dd></div>
                        <div><dt>Type:</dt><dd>Group task</dd></div>
                    </dl>
                </aside>
            </div>

            <div class="task-view-comments">
                <h2>Comments</h2>
                <div class="task-comment-list">
                    <article class="task-comment-item">
                        <div class="task-comment-main">
                            <div class="task-comment-head">
                                <span class="task-comment-avatar" aria-hidden="true">M</span>
                                <span class="task-comment-author">@commentAuthorName</span>
                            </div>
                            <p class="task-comment-text">Погоджуюсь з описом задачі. Беру в роботу сьогодні і до дедлайну закрию.</p>
                        </div>

                        @if (canDeleteComment)
                        {
                            <div class="task-comment-actions">
                                <button type="button" class="task-comment-delete-btn">Delete</button>
                            </div>
                        }
                    </article>

                    <article class="task-comment-item">
                        <div class="task-comment-main">
                            <div class="task-comment-head">
                                <span class="task-comment-avatar" aria-hidden="true">R</span>
                                <span class="task-comment-author">@secondCommentAuthorName</span>
                            </div>
                            <p class="task-comment-text">Додав правки до структури і виніс частину задач у наступний спринт.</p>
                        </div>

                        @if (canDeleteSecondComment)
                        {
                            <div class="task-comment-actions">
                                <button type="button" class="task-comment-delete-btn">Delete</button>
                            </div>
                        }
                    </article>

                    <article class="task-comment-item">
                        <div class="task-comment-main">
                            <div class="task-comment-head">
                                <span class="task-comment-avatar" aria-hidden="true">O</span>
                                <span class="task-comment-author">Olha</span>
                            </div>
                            <p class="task-comment-text">Оновила чеклист по acceptance criteria і додала уточнення щодо перевірки статусів перед релізом.</p>
                        </div>
                    </article>
                </div>

                <div class="task-view-editor js-rich-editor">
                    <div class="task-view-editor-head">
                        <div class="task-view-editor-tools" aria-label="Comment formatting">
                            <button class="task-view-tool-btn js-rich-format-btn" type="button" data-command="bold" aria-label="Bold">B</button>
                            <button class="task-view-tool-btn js-rich-format-btn" type="button" data-command="italic" aria-label="Italic"><em>I</em></button>
                            <button class="task-view-tool-btn js-rich-format-btn" type="button" data-command="underline" aria-label="Underline"><u>U</u></button>
                            <button class="task-view-tool-btn js-rich-format-btn" type="button" data-command="strikeThrough" aria-label="Strike through"><s>S</s></button>
                        </div>
                        <button class="task-view-comment-btn" type="button">Add a comment</button>
                    </div>
                    <div class="task-view-comment-input js-rich-editor-input" contenteditable="true" role="textbox" aria-multiline="true" data-placeholder="Write a comment..."></div>
                </div>
            </div>
        </div>
    </section>
</section>