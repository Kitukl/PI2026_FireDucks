@{
    ViewData["Title"] = "Task board";
    var doneCheckDeadline = DateTime.Today.AddDays(2).ToString("yyyy-MM-dd");
}

<section class="taskboard-page">
    <div class="taskboard-toolbar">
        <label class="taskboard-search" for="task-search">
            <span class="taskboard-search-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                    <path d="M10.5 3a7.5 7.5 0 0 1 5.96 12.06l4.24 4.24-1.42 1.42-4.24-4.24A7.5 7.5 0 1 1 10.5 3zm0 2a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11z"></path>
                </svg>
            </span>
            <input id="task-search" type="search" placeholder="Search" aria-label="Search tasks" />
        </label>

        <div class="taskboard-filter-control js-task-filter-control">
            <button class="taskboard-filter-btn js-task-filter-toggle" type="button" aria-expanded="false">
                <span class="taskboard-filter-icon">&#9776;</span>
                Filter by
            </button>

            <div class="taskboard-filter-dropdown" hidden>
                <button class="taskboard-filter-all js-task-filter-all" type="button">Unselect all</button>
                <label class="taskboard-filter-option"><input class="js-task-filter-checkbox" type="checkbox" value="Subject#A" checked />Subject#A</label>
                <label class="taskboard-filter-option"><input class="js-task-filter-checkbox" type="checkbox" value="Subject#B" checked />Subject#B</label>
                <label class="taskboard-filter-option"><input class="js-task-filter-checkbox" type="checkbox" value="Subject#C" checked />Subject#C</label>
                <label class="taskboard-filter-option"><input class="js-task-filter-checkbox" type="checkbox" value="Subject#D" checked />Subject#D</label>
                <label class="taskboard-filter-option"><input class="js-task-filter-checkbox" type="checkbox" value="Subject#E" checked />Subject#E</label>
                <label class="taskboard-filter-option"><input class="js-task-filter-checkbox" type="checkbox" value="Subject#F" checked />Subject#F</label>
                <label class="taskboard-filter-option"><input class="js-task-filter-checkbox" type="checkbox" value="Subject#G" checked />Subject#G</label>
            </div>
        </div>

        <a class="taskboard-create-btn" asp-area="" asp-controller="Home" asp-action="TaskBoardCreate">Create task</a>
    </div>

    <div class="taskboard-grid">
        <aside class="taskboard-sidebar">
            <div class="taskboard-sidebar-group">
                <div class="taskboard-sidebar-title">Own tasks <button class="taskboard-radio js-task-scope-filter" type="button" data-scope="own" aria-label="Show own tasks"></button></div>
                <ul>
                    <li><span>To do</span><strong>0</strong></li>
                    <li><span>In progress</span><strong>1</strong></li>
                    <li><span>For review</span><strong>2</strong></li>
                    <li><span>Done</span><strong>1</strong></li>
                </ul>
            </div>

            <div class="taskboard-sidebar-group">
                <div class="taskboard-sidebar-title">Group tasks <button class="taskboard-radio js-task-scope-filter" type="button" data-scope="group" aria-label="Show group tasks"></button></div>
                <ul>
                    <li><span>To do</span><strong>1</strong></li>
                    <li><span>In progress</span><strong>1</strong></li>
                    <li><span>For review</span><strong>1</strong></li>
                    <li><span>Done</span><strong>1</strong></li>
                </ul>
            </div>

            <div class="taskboard-sidebar-group">
                <div class="taskboard-sidebar-title">All tasks <button class="taskboard-radio js-task-scope-filter active" type="button" data-scope="all" aria-label="Show all tasks"></button></div>
                <ul>
                    <li><span>To do</span><strong>1</strong></li>
                    <li><span>In progress</span><strong>2</strong></li>
                    <li><span>For review</span><strong>3</strong></li>
                    <li><span>Done</span><strong>2</strong></li>
                </ul>
            </div>

            @if (User.IsInRole("Leader"))
            {
                <a class="taskboard-manage-btn" asp-area="" asp-controller="Home" asp-action="TaskBoardReviewGroup">Manage group</a>
            }
        </aside>

        <div class="taskboard-columns-scroll">

        <section class="taskboard-column">
            <h2>To do</h2>
            <article class="task-card">
                <header>
                    <h3>New Task#7</h3>
                    <span class="task-card-status"></span>
                </header>
                <p>Subject#A</p>
                <div class="task-card-meta">
                    <span class="task-group-label"><span class="task-group-icon" aria-hidden="true"><svg viewBox="0 0 24 24" focusable="false" aria-hidden="true"><path d="M9 11a3 3 0 1 0-3-3 3 3 0 0 0 3 3zm6 0a3 3 0 1 0-3-3 3 3 0 0 0 3 3zM5 18v-1a3 3 0 0 1 3-3h2a3 3 0 0 1 3 3v1m-2 0v-1a3 3 0 0 1 3-3h2a3 3 0 0 1 3 3v1"></path></svg></span><span>Group task</span></span>
                    <span class="task-card-badge">&#128100;</span>
                </div>
                <footer><a class="task-card-link" asp-area="" asp-controller="Home" asp-action="TaskBoardViewTask" asp-route-taskCode="A-3">A-3</a></footer>
