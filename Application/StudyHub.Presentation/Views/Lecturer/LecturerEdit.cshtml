@model StudyHub.Core.DTOs.LecturerDtoRequest

<div class="container mt-4">
    <h2>Редагування викладача</h2>
    <hr />

    <form asp-action="Edit">
        <input type="hidden" asp-for="Id" />

        <div class="row">
            <div class="col-md-6">
                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Ім'я</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="Surname" class="form-label">Прізвище</label>
                    <input asp-for="Surname" class="form-control" />
                    <span asp-validation-for="Surname" class="text-danger"></span>
                </div>
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-header bg-warning d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Керування уроками</h5>
                <button type="button" id="btnAddLesson" class="btn btn-dark btn-sm">+ Додати заняття</button>
            </div>
            <div class="card-body">
                <table class="table" id="lessonsTable">
                    <thead>
                        <tr>
                            <th>День</th>
                            <th>Тип</th>
                            <th>Предмет</th>
                            <th>Слот</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Lessons.Count; i++)
                        {
                            <tr>
                                <td>
                                    <select name="lecturer.Lessons[@i].Day" class="form-select">
                                        <option value="1" selected="@(Model.Lessons[i].Day == DayOfWeek.Monday)">Понеділок</option>
                                        <option value="2" selected="@(Model.Lessons[i].Day == DayOfWeek.Tuesday)">Вівторок</option>
                                        <option value="3" selected="@(Model.Lessons[i].Day == DayOfWeek.Wednesday)">Середа</option>
                                        <option value="4" selected="@(Model.Lessons[i].Day == DayOfWeek.Thursday)">Четвер</option>
                                        <option value="5" selected="@(Model.Lessons[i].Day == DayOfWeek.Friday)">П'ятниця</option>
                                    </select>
                                </td>
                                <td>
                                    <input name="lecturer.Lessons[@i].LessonType" value="@Model.Lessons[i].LessonType" class="form-control" />
                                </td>
                                <td>
                                    <select name="lecturer.Lessons[@i].Subject.Id" class="form-select">
                                        @foreach (var s in (SelectList)ViewBag.Subjects)
                                        {
                                            <option value="@s.Value" selected="@(s.Value == Model.Lessons[i].Subject.Id.ToString())">@s.Text</option>
                                        }
                                    </select>
                                </td>
                                <td>
                                    <select name="lecturer.Lessons[@i].LessonSlot.Id" class="form-select">
                                        @foreach (var s in (SelectList)ViewBag.Slots)
                                        {
                                            <option value="@s.Value" selected="@(s.Value == Model.Lessons[i].LessonSlot.Id.ToString())">@s.Text</option>
                                        }
                                    </select>
                                </td>
                                <td>
                                    <button type="button" class="btn btn-outline-danger remove-row">✕</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-4">
            <button type="submit" class="btn btn-success px-4">Зберегти зміни</button>
            <a asp-action="Index" class="btn btn-secondary">Скасувати</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        let index = @Model.Lessons.Count;

        $("#btnAddLesson").click(function () {
            const row = `
                <tr>
                    <td>
                        <select name="lecturer.Lessons[${index}].Day" class="form-select">
                            <option value="1">Понеділок</option>
                            <option value="2">Вівторок</option>
                            <option value="3">Середа</option>
                            <option value="4">Четвер</option>
                            <option value="5">П'ятниця</option>
                        </select>
                    </td>
                    <td>
                        <input name="lecturer.Lessons[${index}].LessonType" class="form-control" />
                    </td>
                    <td>
                        <select name="lecturer.Lessons[${index}].Subject.Id" class="form-select">
                            @foreach (var s in (SelectList)ViewBag.Subjects)
                            {
                                    <option value="@s.Value">@s.Text</option>
                            }
                        </select>
                    </td>
                    <td>
                        <select name="lecturer.Lessons[${index}].LessonSlot.Id" class="form-select">
                            @foreach (var s in (SelectList)ViewBag.Slots)
                            {
                                    <option value="@s.Value">@s.Text</option>
                            }
                        </select>
                    </td>
                    <td>
                        <button type="button" class="btn btn-outline-danger remove-row">✕</button>
                    </td>
                </tr>`;
            $("#lessonsTable tbody").append(row);
            index++;
        });

        $(document).on("click", ".remove-row", function () {
            $(this).closest("tr").remove();
        });
    </script>
}