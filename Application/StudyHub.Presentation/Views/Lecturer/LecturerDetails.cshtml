@model StudyHub.Core.DTOs.LecturerDtoResponse

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Профіль викладача</h2>
        <div>
            <a asp-action="LecturerEdit" asp-route-id="@Model.Id" class="btn btn-warning">Редагувати</a>
            <a asp-action="LecturersList" class="btn btn-secondary">Назад до списку</a>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Основна інформація</h5>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-2">Прізвище:</dt>
                <dd class="col-sm-10">@Model.Surname</dd>

                <dt class="col-sm-2">Ім'я:</dt>
                <dd class="col-sm-10">@Model.Name</dd>

                <dt class="col-sm-2">ID системи:</dt>
                <dd class="col-sm-10 text-muted small">@Model.Id</dd>
            </dl>
        </div>
    </div>

@*     <div class="card">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Розклад занять</h5>
        </div>
