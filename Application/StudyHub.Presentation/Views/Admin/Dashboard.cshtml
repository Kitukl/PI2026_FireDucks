    margin: 0 auto;
}

.admin-report-task-row {
    border: 1px solid rgba(14, 30, 51, 0.18);
    border-radius: 10px;
    padding: 10px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 138px;
    gap: 12px;
    align-items: center;
    width: min(660px, 100%);
    margin: 0 auto;
}

.admin-report-task-info {
    display: grid;
    gap: 8px;
}

.admin-report-task-info h4 {
    margin: 0;
    font-size: 1.04rem;
    font-weight: 800;
}

.admin-report-task-lines {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 5px;
}

.admin-report-task-lines li {
    display: grid;
    grid-template-columns: 140px 34px 10px 50px;
    justify-content: start;
    gap: 4px;
    align-items: center;
    font-size: 0.92rem;
}

.admin-report-task-label {
    display: inline-grid;
    grid-template-columns: 14px auto;
    align-items: center;
    gap: 4px;
}

.admin-report-task-name {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.admin-report-task-count,
.admin-report-task-percent {
    font-weight: 800;
    text-align: right;
    justify-self: end;
}

.admin-report-task-dash {
    text-align: center;
    font-weight: 800;
    color: #33435b;
}

.admin-report-legend {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 6px;
}

.admin-report-legend li {
    display: grid;
    grid-template-columns: 14px 1fr;
    gap: 8px;
    align-items: center;
    font-size: 0.9rem;
    font-weight: 700;
}

.admin-report-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
}

@@media (max-width: 1100px) {
    .admin-dashboard-main-grid {
        grid-template-columns: 1fr;
    }

    .admin-task-summary-layout {
        grid-template-columns: 1fr;
    }

    .admin-task-chart-wrap {
        grid-template-columns: 1fr;
    }

    .admin-count-summary-grid {
        grid-template-columns: 1fr;
    }

    .admin-report-paper {
        width: 100%;
        min-height: 0;
        padding: 18px;
    }

    .admin-report-count-grid {
        grid-template-columns: 1fr;
    }

    .admin-report-task-row {
        grid-template-columns: 1fr;
    }
