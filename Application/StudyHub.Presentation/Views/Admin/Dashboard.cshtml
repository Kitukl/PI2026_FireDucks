    gap: 12px;
}

.admin-task-scope-card {
    border: 1px solid rgba(18, 24, 38, 0.15);
    border-radius: 12px;
    background: #fff;
    padding: 10px;
}

.admin-task-scope-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
}

.admin-task-scope-top h3 {
    margin: 0;
    color: #101f34;
    font-size: 1.05rem;
    font-weight: 800;
}

.admin-task-scope-radio {
