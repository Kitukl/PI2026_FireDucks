}

.admin-report-count-card {
    border: 1px solid rgba(14, 30, 51, 0.2);
    border-radius: 10px;
    padding: 9px;
}

.admin-report-count-card h4 {
    margin: 0;
    font-size: 1.02rem;
    font-weight: 800;
}

.admin-report-count-card ul {
    list-style: none;
    margin: 8px 0 0;
    padding: 0;
    display: grid;
    gap: 5px;
}

.admin-report-count-card li {
    display: grid;
    grid-template-columns: auto auto;
    justify-content: space-between;
    gap: 3px;
    font-size: 0.95rem;
}

.admin-report-task-rows {
    display: grid;
