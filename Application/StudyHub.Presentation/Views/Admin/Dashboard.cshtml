@model Application.Models.SystemStatisticViewModel
@using System.Text.Json
@using System.Globalization
@using StudyHub.Domain.Enums
@{
    Layout = "_Layout";
    ViewData["Title"] = "Admin Dashboard";

    var groupedTasks = Model.GropedTaskCount ?? new Dictionary<string, Dictionary<string, int>>();
    var userTaskStatsRaw = groupedTasks.TryGetValue("User Tasks", out var userTasks)
        ? userTasks
        : new Dictionary<string, int>();
    var groupTaskStatsRaw = groupedTasks.TryGetValue("Group Tasks", out var groupTasks)
        ? groupTasks
        : new Dictionary<string, int>();

    var statusOrder = new[]
    {
        (Key: nameof(Status.ToDo), Label: "To do", Color: "#d9ebff"),
        (Key: nameof(Status.InProgress), Label: "In progress", Color: "#8fc2ff"),
        (Key: nameof(Status.ForReview), Label: "For review", Color: "#4e8fda"),
        (Key: nameof(Status.Done), Label: "Done", Color: "#1c4f9f")
    };

    int ResolveStatusCount(Dictionary<string, int> source, string statusKey)
    {
        if (source.TryGetValue(statusKey, out var directValue))
        {
            return directValue;
        }

        var compactKey = statusKey.Replace(" ", string.Empty, StringComparison.Ordinal).Replace("_", string.Empty, StringComparison.Ordinal);
        foreach (var item in source)
        {
            var itemKey = (item.Key ?? string.Empty)
                .Replace(" ", string.Empty, StringComparison.Ordinal)
                .Replace("_", string.Empty, StringComparison.Ordinal);

            if (string.Equals(itemKey, compactKey, StringComparison.OrdinalIgnoreCase))
            {
                return item.Value;
            }
        }

        return 0;
    }

    Dictionary<string, int> BuildNormalizedStatusStats(Dictionary<string, int> source)
    {
        return statusOrder.ToDictionary(
            s => s.Label,
            s => ResolveStatusCount(source, s.Key)
        );
    }

    var userTaskStats = BuildNormalizedStatusStats(userTaskStatsRaw);
    var groupTaskStats = BuildNormalizedStatusStats(groupTaskStatsRaw);
    var totalTaskStats = statusOrder.ToDictionary(
        s => s.Label,
        s => userTaskStats[s.Label] + groupTaskStats[s.Label]
    );

    var totalUserTasks = userTaskStats.Values.Sum();
    var totalGroupTasks = groupTaskStats.Values.Sum();
    var totalTasks = totalTaskStats.Values.Sum();

    string BuildPieStyle(Dictionary<string, int> stats)
    {
        var total = stats.Values.Sum();
        if (total <= 0)
        {
            return "background: conic-gradient(#edf1f7 0deg 360deg);";
        }

        var cursor = 0.0;
        var segments = new List<string>(statusOrder.Length);

        foreach (var status in statusOrder)
        {
            var count = stats[status.Label];
            var sweep = count * 360.0 / total;
            var from = cursor;
            var to = cursor + sweep;
            var fromText = from.ToString("F2", CultureInfo.InvariantCulture);
            var toText = to.ToString("F2", CultureInfo.InvariantCulture);
            segments.Add($"{status.Color} {fromText}deg {toText}deg");
            cursor = to;
        }

        return $"background: conic-gradient({string.Join(", ", segments)});";
    }

    var chartData = new
    {
        user = userTaskStats,
        group = groupTaskStats,
        all = totalTaskStats
    };

    var chartDataJson = JsonSerializer.Serialize(chartData);
}

<style>
