    align-items: center;
    gap: 10px;
}

.admin-report-paper {
    width: 794px;
    min-height: 0;
    margin: 0 auto;
    background: #fff;
    padding: 34px 34px 28px;
    color: #0f2139;
}

.admin-report-title {
    margin: 0;
    text-align: center;
    font-size: 2.05rem;
    font-weight: 800;
    letter-spacing: 0.01em;
}

.admin-report-title .study {
    color: #2e99cd;
}

.admin-report-title .hub {
