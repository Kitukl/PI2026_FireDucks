</style>

<section class="admin-page" aria-label="Admin dashboard">
    <div class="admin-page-header" style="padding-bottom: 4px; margin-bottom: 6px;">
        <div>
            <h1 class="admin-dashboard-title">Dashboard</h1>
        </div>
    </div>

    <div class="admin-dashboard-main-grid">
        <article class="admin-panel">
            <header class="admin-panel-head">
                <h2>Task status summary</h2>
            </header>

            <div class="admin-task-summary-layout" id="taskStatusSummary" data-chart='@Html.Raw(chartDataJson)'>
                <section class="admin-task-scope-list">
                    <article class="admin-task-scope-card" data-scope="user">
                        <div class="admin-task-scope-top">
                            <h3>User tasks</h3>
                            <input class="admin-task-scope-radio js-task-scope-radio" type="radio" name="taskScope" value="user" aria-label="Show user task chart" />
                        </div>
                        <ul class="admin-task-scope-list-rows">
                            @foreach (var status in statusOrder)
                            {
                                <li><span>@status.Label</span><strong>@userTaskStats[status.Label]</strong></li>
                            }
                        </ul>
                    </article>

                    <article class="admin-task-scope-card" data-scope="group">
                        <div class="admin-task-scope-top">
                            <h3>Group tasks</h3>
                            <input class="admin-task-scope-radio js-task-scope-radio" type="radio" name="taskScope" value="group" aria-label="Show group task chart" />
                        </div>
                        <ul class="admin-task-scope-list-rows">
                            @foreach (var status in statusOrder)
                            {
                                <li><span>@status.Label</span><strong>@groupTaskStats[status.Label]</strong></li>
                            }
                        </ul>
                    </article>

                    <article class="admin-task-scope-card" data-scope="all">
                        <div class="admin-task-scope-top">
                            <h3>All tasks</h3>
                            <input class="admin-task-scope-radio js-task-scope-radio" type="radio" name="taskScope" value="all" checked aria-label="Show all task chart" />
                        </div>
                        <ul class="admin-task-scope-list-rows">
                            @foreach (var status in statusOrder)
                            {
                                <li><span>@status.Label</span><strong>@totalTaskStats[status.Label]</strong></li>
                            }
                        </ul>
                    </article>
                </section>

                <section class="admin-task-chart-wrap">
                    <div class="admin-task-chart js-admin-task-chart" style="@BuildPieStyle(totalTaskStats)">
                    </div>

                    <ul class="admin-task-legend">
                        @for (var index = 0; index < statusOrder.Length; index++)
                        {
                            var status = statusOrder[index];
                            <li>
                                <span class="admin-task-legend-dot" style="background: @status.Color;"></span>
                                <span>@status.Label</span>
                                <span class="admin-task-legend-percent js-admin-task-legend-percent" data-status-index="@index">0%</span>
                            </li>
                        }
                    </ul>
                </section>
            </div>
        </article>

        <article class="admin-panel">
            <header class="admin-panel-head">
                <h2>Count summary</h2>
            </header>

            <div class="admin-count-summary-grid">
                <section class="admin-count-summary-card">
                    <h3>Users</h3>
                    <ul class="admin-count-summary-list">
                        <li><span>Students</span><strong>@Model.StudentsCount</strong></li>
                        <li><span>Groups</span><strong>@Model.GroupsCount</strong></li>
                        <li><span>Leaders</span><strong>@Model.LeadersCount</strong></li>
                    </ul>
                </section>

                <section class="admin-count-summary-card">
                    <h3>Tasks</h3>
                    <ul class="admin-count-summary-list">
                        <li><span>User tasks</span><strong>@totalUserTasks</strong></li>
                        <li><span>Group tasks</span><strong>@totalGroupTasks</strong></li>
                        <li><span>All tasks</span><strong>@totalTasks</strong></li>
                    </ul>
                </section>

                <section class="admin-count-summary-card">
                    <h3>Files</h3>
                    <ul class="admin-count-summary-list">
                        <li><span>User files</span><strong>@Model.UserFilesCount</strong></li>
                        <li><span>Group files</span><strong>@Model.GroupFilesCount</strong></li>
                        <li><span>All files</span><strong>@Model.FileCount</strong></li>
                    </ul>
                </section>
            </div>
        </article>
    </div>

    <div class="admin-dashboard-actions">
        <button type="button" class="admin-btn admin-btn-primary js-open-report-preview">Preview PDF</button>
    </div>
</section>

<div class="admin-report-backdrop js-report-backdrop" hidden></div>
<div class="admin-report-modal js-report-modal" hidden>
    <div class="admin-report-shell">
        <div class="admin-report-head">
            <strong>PDF preview</strong>
            <div class="admin-actions-inline">
                <button type="button" class="admin-btn admin-btn-primary js-download-report-pdf">Download PDF</button>
                <button type="button" class="admin-btn js-close-report-preview">Close</button>
            </div>
        </div>

        <article class="admin-report-paper js-report-paper">
            <h2 class="admin-report-title"><span class="study">Study</span><span class="hub">Hub</span> Usage Report</h2>
            <p class="admin-report-created">Created at @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>

            <section class="admin-report-section">
                    <h3>Count summary</h3>
                <div class="admin-report-count-grid">
                    <article class="admin-report-count-card">
                        <h4>Users</h4>
                        <ul>
                            <li><span>Students</span><strong>@Model.StudentsCount</strong></li>
                            <li><span>Groups</span><strong>@Model.GroupsCount</strong></li>
                            <li><span>Leaders</span><strong>@Model.LeadersCount</strong></li>
                        </ul>
                    </article>

                    <article class="admin-report-count-card">
                        <h4>Tasks</h4>
                        <ul>
                            <li><span>User tasks</span><strong>@totalUserTasks</strong></li>
                            <li><span>Group tasks</span><strong>@totalGroupTasks</strong></li>
                            <li><span>All tasks</span><strong>@totalTasks</strong></li>
                        </ul>
                    </article>

                    <article class="admin-report-count-card">
                        <h4>Files</h4>
                        <ul>
                            <li><span>User files</span><strong>@Model.UserFilesCount</strong></li>
                            <li><span>Group files</span><strong>@Model.GroupFilesCount</strong></li>
                            <li><span>All files</span><strong>@Model.FileCount</strong></li>
                        </ul>
                    </article>
                </div>
            </section>

            <section class="admin-report-section">
                    <h3>Task status summary</h3>
                <div class="admin-report-task-rows">
                    <article class="admin-report-task-row">
                        <div class="admin-report-task-info">
                            <h4>User tasks</h4>
                            <ul class="admin-report-task-lines">
                                @foreach (var status in statusOrder)
                                {
                                    var value = userTaskStats[status.Label];
                                    var percent = totalUserTasks > 0 ? Math.Round(value * 100.0 / totalUserTasks, 1) : 0;
                                    <li>
                                        <span class="admin-report-task-label"><span class="admin-report-dot" style="background: @status.Color;"></span><span class="admin-report-task-name">@status.Label</span></span>
                                        <span class="admin-report-task-count">@value</span>
                                        <span class="admin-report-task-dash">—</span>
                                        <span class="admin-report-task-percent">@percent%</span>
                                    </li>
                                }
                            </ul>
                        </div>
                        <div class="admin-report-mini-chart js-admin-report-mini-chart" data-scope="user" style="@BuildPieStyle(userTaskStats)"></div>
                    </article>

                    <article class="admin-report-task-row">
                        <div class="admin-report-task-info">
                            <h4>Group tasks</h4>
                            <ul class="admin-report-task-lines">
                                @foreach (var status in statusOrder)
                                {
                                    var value = groupTaskStats[status.Label];
                                    var percent = totalGroupTasks > 0 ? Math.Round(value * 100.0 / totalGroupTasks, 1) : 0;
                                    <li>
                                        <span class="admin-report-task-label"><span class="admin-report-dot" style="background: @status.Color;"></span><span class="admin-report-task-name">@status.Label</span></span>
                                        <span class="admin-report-task-count">@value</span>
                                        <span class="admin-report-task-dash">—</span>
                                        <span class="admin-report-task-percent">@percent%</span>
                                    </li>
                                }
                            </ul>
                        </div>
                        <div class="admin-report-mini-chart js-admin-report-mini-chart" data-scope="group" style="@BuildPieStyle(groupTaskStats)"></div>
                    </article>

                    <article class="admin-report-task-row">
                        <div class="admin-report-task-info">
                            <h4>All tasks</h4>
                            <ul class="admin-report-task-lines">
                                @foreach (var status in statusOrder)
                                {
                                    var value = totalTaskStats[status.Label];
                                    var percent = totalTasks > 0 ? Math.Round(value * 100.0 / totalTasks, 1) : 0;
                                    <li>
                                        <span class="admin-report-task-label"><span class="admin-report-dot" style="background: @status.Color;"></span><span class="admin-report-task-name">@status.Label</span></span>
                                        <span class="admin-report-task-count">@value</span>
                                        <span class="admin-report-task-dash">—</span>
                                        <span class="admin-report-task-percent">@percent%</span>
                                    </li>
                                }
                            </ul>
                        </div>
                        <div class="admin-report-mini-chart js-admin-report-mini-chart" data-scope="all" style="@BuildPieStyle(totalTaskStats)"></div>
                    </article>
                </div>
            </section>
        </article>
    </div>
</div>

<script>
(() => {
    const statusOrder = ["To do", "In progress", "For review", "Done"];
    const colors = ["#d9ebff", "#8fc2ff", "#4e8fda", "#1c4f9f"];
    const summaryRoot = document.getElementById("taskStatusSummary");
    const chartNode = document.querySelector(".js-admin-task-chart");
    const scopeRadios = Array.from(document.querySelectorAll(".js-task-scope-radio"));
    const legendPercentNodes = Array.from(document.querySelectorAll(".js-admin-task-legend-percent"));
    const reportMiniCharts = Array.from(document.querySelectorAll(".js-admin-report-mini-chart"));
    const chartData = summaryRoot ? JSON.parse(summaryRoot.dataset.chart || "{}") : {};

    function normalizeScopeData(scopeKey) {
        const source = chartData[scopeKey] || {};
        return statusOrder.map(status => Number(source[status] || 0));
    }

    function applyReportMiniCharts() {
        if (!reportMiniCharts.length) {
            return;
        }

        reportMiniCharts.forEach(node => {
            const scopeKey = node.getAttribute("data-scope") || "all";
            const values = normalizeScopeData(scopeKey);
            const total = values.reduce((acc, value) => acc + value, 0);

            if (total <= 0) {
                node.style.background = "conic-gradient(#edf1f7 0deg 360deg)";
                return;
            }

            let cursor = 0;
            const segments = values.map((value, index) => {
                const sweep = value * 360 / total;
                const from = cursor;
                const to = cursor + sweep;
                cursor = to;
                return `${colors[index]} ${from.toFixed(2)}deg ${to.toFixed(2)}deg`;
            });

            node.style.background = "conic-gradient(" + segments.join(", ") + ")";
            node.style.backgroundColor = "#edf1f7";
        });
    }

    if (summaryRoot && chartNode && scopeRadios.length && legendPercentNodes.length) {
        function applyChart(scopeKey) {
            const values = normalizeScopeData(scopeKey);
            const total = values.reduce((acc, value) => acc + value, 0);

            if (total <= 0) {
                chartNode.style.background = "conic-gradient(#edf1f7 0deg 360deg)";
                legendPercentNodes.forEach(node => {
                    node.textContent = "0%";
                });
                return;
            }

            let cursor = 0;
            const percentages = values.map(value => (value * 100) / total);
            const segments = values.map((value, index) => {
                const sweep = value * 360 / total;
                const from = cursor;
                const to = cursor + sweep;
                cursor = to;

                if (legendPercentNodes[index]) {
                    legendPercentNodes[index].textContent = `${Math.round(percentages[index] * 10) / 10}%`;
                }

                return `${colors[index]} ${from.toFixed(2)}deg ${to.toFixed(2)}deg`;
            });

            chartNode.style.background = "conic-gradient(" + segments.join(", ") + ")";
            chartNode.style.backgroundColor = "#edf1f7";
        }

        scopeRadios.forEach(radio => {
            radio.addEventListener("change", () => {
                if (radio.checked) {
                    applyChart(radio.value);
                }
            });
        });

        const checkedScope = scopeRadios.find(radio => radio.checked)?.value || "all";
        applyChart(checkedScope);
    }

    applyReportMiniCharts();

    const openPreviewButton = document.querySelector(".js-open-report-preview");
    const closePreviewButton = document.querySelector(".js-close-report-preview");
    const reportBackdrop = document.querySelector(".js-report-backdrop");
    const reportModal = document.querySelector(".js-report-modal");
    const reportPaper = document.querySelector(".js-report-paper");
    const downloadPdfButton = document.querySelector(".js-download-report-pdf");

    function setPreviewVisible(isVisible) {
        if (!reportBackdrop || !reportModal) {
            return;
        }

        reportBackdrop.hidden = !isVisible;
        reportModal.hidden = !isVisible;
        document.body.style.overflow = isVisible ? "hidden" : "";
    }

    openPreviewButton?.addEventListener("click", () => setPreviewVisible(true));
    openPreviewButton?.addEventListener("click", applyReportMiniCharts);
    closePreviewButton?.addEventListener("click", () => setPreviewVisible(false));
    reportBackdrop?.addEventListener("click", () => setPreviewVisible(false));

    function loadScript(src) {
        return new Promise((resolve, reject) => {
            const existing = document.querySelector(`script[src='${src}']`);
            if (existing) {
                resolve();
                return;
            }

            const script = document.createElement("script");
            script.src = src;
            script.onload = () => resolve();
            script.onerror = () => reject(new Error("Cannot load script"));
            document.head.appendChild(script);
        });
    }

    function createPieChartImage(values, size) {
        const canvas = document.createElement("canvas");
        canvas.width = size;
        canvas.height = size;

        const context = canvas.getContext("2d");
        if (!context) {
            return "";
        }

        const total = values.reduce((acc, value) => acc + value, 0);
        const center = size / 2;
        const radius = center - 1;

        if (total <= 0) {
            context.fillStyle = "#edf1f7";
            context.beginPath();
            context.arc(center, center, radius, 0, Math.PI * 2);
            context.fill();
            return canvas.toDataURL("image/png");
        }

        let cursor = -Math.PI / 2;

        values.forEach((value, index) => {
            if (value <= 0) {
                return;
            }

            const sweep = (value / total) * Math.PI * 2;
            context.beginPath();
            context.moveTo(center, center);
            context.arc(center, center, radius, cursor, cursor + sweep);
            context.closePath();
            context.fillStyle = colors[index] || "#edf1f7";
            context.fill();
            cursor += sweep;
        });

        return canvas.toDataURL("image/png");
    }

    function renderChartsForPdfExport(exportNode) {
        const exportCharts = Array.from(exportNode.querySelectorAll(".js-admin-report-mini-chart"));
        if (!exportCharts.length) {
            return;
        }

        exportCharts.forEach(node => {
            const scopeKey = node.getAttribute("data-scope") || "all";
            const values = normalizeScopeData(scopeKey);
            const imageDataUrl = createPieChartImage(values, 360);
            if (!imageDataUrl) {
                return;
            }

            const img = document.createElement("img");
            img.src = imageDataUrl;
            img.alt = "Task chart";
            img.style.display = "block";
            img.style.width = "100%";
            img.style.height = "100%";
            img.style.borderRadius = "50%";

            node.style.background = "none";
            node.style.backgroundColor = "transparent";
            node.replaceChildren(img);
        });
    }

    downloadPdfButton?.addEventListener("click", async () => {
        if (!reportPaper) {
            return;
        }

        try {
            await loadScript("https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js");
        } catch {
            alert("Unable to load PDF exporter. Please try again.");
            return;
        }

        const exportNode = reportPaper.cloneNode(true);
        exportNode.style.width = "794px";
        exportNode.style.minHeight = "0";
        renderChartsForPdfExport(exportNode);

        const options = {
            margin: [8, 8, 8, 8],
            filename: `studyhub-report-${new Date().toISOString().slice(0, 10)}.pdf`,
            image: { type: "jpeg", quality: 0.98 },
            html2canvas: { scale: 2, useCORS: true, backgroundColor: "#ffffff" },
            jsPDF: { unit: "mm", format: "a4", orientation: "portrait" },
            pagebreak: { mode: ["css", "legacy"] }
        };

        window.html2pdf().set(options).from(exportNode).save();
    });
})();
</script>
