@model Application.Models.SystemStatisticViewModel
@using System.Globalization

@{
    ViewBag.Title = "title";
    Layout = "_Layout";
}


<h1>Статистика</h1>
<p>created at @Model.CreatedAt</p>
<p> users files @Model.FileCount </p>
<p> task All @Model.TaskCount</p>

<div>
    @foreach (var (kind, statusDict) in Model.GropedTaskCount)
    {
        <h2>@kind</h2>
        foreach (var (status,count) in statusDict)
        {
            <p>@status : @count</p>    
        }
    }
</div>

<div>
    <p>User Activity Per Month</p>
    <ul class="list-group">
        @foreach (var (month, value) in Model.UserActivityPerMonth)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <span>
                    <strong>
                        @CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(month)
                    </strong>
                </span>
                <span class="badge bg-primary rounded-pill">@value.ToString("F2")</span>
            </li>
        }
    </ul>
</div>

<div>
    <h2>Tasks</h2>
    @foreach (var (kind, statusDict) in Model.GropedTaskCount)
    {
        <p>@kind : @statusDict.Sum(s=>s.Value) </p>
    }
    
    <h2>Files</h2>
    <p>All files : @Model.FileCount</p>
</div>