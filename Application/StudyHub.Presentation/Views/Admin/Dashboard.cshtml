    justify-content: space-between;
    color: #1d2d44;
    font-size: 1rem;
}

.admin-task-scope-list-rows strong {
    font-weight: 800;
}

.admin-task-chart-wrap {
    border: 0;
    border-radius: 0;
    background: transparent;
    padding: 30px 10px 10px;
    display: grid;
    grid-template-columns: minmax(220px, 320px) minmax(180px, 260px);
    align-items: center;
    justify-content: center;
    gap: 16px;
    align-self: center;
    transform: translateY(-10%);
}

.admin-task-chart {
    width: min(300px, 58vw);
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    border: 1px solid rgba(16, 32, 54, 0.08);
    margin: 0 auto;
    position: relative;
    background: #edf1f7;
}

.admin-task-legend {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 10px;
}

.admin-task-legend li {
    display: grid;
    grid-template-columns: 18px 1fr auto;
    align-items: center;
    gap: 10px;
    color: #1d2f49;
    font-size: 1.02rem;
    font-weight: 700;
}

.admin-task-legend-dot {
    width: 18px;
    height: 18px;
    border-radius: 50%;
}

.admin-task-legend-percent {
    color: #2c3d56;
    font-weight: 800;
}

.admin-dashboard-actions {
    display: flex;
    justify-content: center;
    margin-top: 14px;
}

.admin-report-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(16, 25, 39, 0.5);
    z-index: 120;
}

.admin-report-modal {
    position: fixed;
    inset: 0;
    z-index: 130;
    overflow: auto;
    padding: 14px 12px;
}

.admin-report-shell {
    width: min(980px, 94vw);
    max-height: calc(100vh - 32px);
    overflow: auto;
    margin: 0 auto;
    background: #f5f7fb;
    border: 1px solid rgba(12, 26, 44, 0.28);
    border-radius: 14px;
    box-shadow: 0 24px 42px rgba(9, 20, 35, 0.32);
}

.admin-report-head {
    position: sticky;
    top: 0;
    z-index: 2;
