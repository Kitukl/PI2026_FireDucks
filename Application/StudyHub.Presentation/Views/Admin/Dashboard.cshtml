    border: 3px solid #3e4653;
    background: #fff;
    cursor: pointer;
}

.admin-task-scope-radio:checked {
    background: #1f2f4b;
}

.admin-task-scope-list-rows {
    list-style: none;
    margin: 8px 0 0;
    padding: 0;
    display: grid;
    gap: 6px;
}

.admin-task-scope-list-rows li {
