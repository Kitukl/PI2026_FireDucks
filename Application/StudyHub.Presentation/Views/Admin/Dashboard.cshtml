    max-width: none;
    margin-left: 0;
    margin-right: 0;
}

.admin-count-summary-card {
    border: 1px solid rgba(18, 24, 38, 0.22);
    border-radius: 12px;
    background: #fff;
    padding: 12px;
}

.admin-count-summary-card h3 {
    margin: 0;
    color: #102238;
    font-size: 1.2rem;
    font-weight: 800;
}

.admin-count-summary-list {
    list-style: none;
    margin: 10px 0 0;
    padding: 0;
    display: grid;
    gap: 8px;
}

.admin-count-summary-list li {
    display: grid;
    grid-template-columns: auto auto;
    justify-content: space-between;
    gap: 3px;
    border: 0;
    border-radius: 0;
    padding: 5px 0;
    color: #27374e;
    font-weight: 600;
}

.admin-count-summary-list strong {
    color: #09203d;
    font-weight: 800;
}

.admin-task-summary-layout {
