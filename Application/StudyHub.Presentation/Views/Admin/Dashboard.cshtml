@model Application.Models.SystemStatisticViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Admin Dashboard";

    var groupedTasks = Model.GropedTaskCount ?? new Dictionary<string, Dictionary<string, int>>();
    var userTaskStats = groupedTasks.TryGetValue("User Tasks", out var userTasks)
        ? userTasks
        : new Dictionary<string, int>();
    var groupTaskStats = groupedTasks.TryGetValue("Group Tasks", out var groupTasks)
        ? groupTasks
        : new Dictionary<string, int>();

    var totalTaskStats = groupedTasks
        .SelectMany(pair => pair.Value)
        .GroupBy(item => item.Key)
        .ToDictionary(group => group.Key, group => group.Sum(item => item.Value));

    var totalUserTasks = userTaskStats.Values.Sum();
    var totalGroupTasks = groupTaskStats.Values.Sum();
    var totalTasks = Model.TaskCount;
}

<section class="admin-page" aria-label="Admin dashboard">
    <div class="admin-page-header">
        <div>
            <h1>Dashboard</h1>
            <p class="admin-page-subtitle">Created at @Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</p>
        </div>
    </div>

    <div class="admin-metric-grid">
        <article class="admin-metric-card">
            <p class="admin-metric-label">Users files</p>
            <p class="admin-metric-value">@Model.FileCount</p>
        </article>
        <article class="admin-metric-card">
            <p class="admin-metric-label">All tasks</p>
            <p class="admin-metric-value">@totalTasks</p>
        </article>
        <article class="admin-metric-card">
            <p class="admin-metric-label">User tasks</p>
            <p class="admin-metric-value">@totalUserTasks</p>
        </article>
        <article class="admin-metric-card">
            <p class="admin-metric-label">Group tasks</p>
            <p class="admin-metric-value">@totalGroupTasks</p>
        </article>
    </div>

    <div>
        <article class="admin-panel">
            <header class="admin-panel-head">
                <h2>Task status summary</h2>
            </header>

            <div class="admin-status-stack">
                <section>
                    <h3>User tasks</h3>
                    <ul class="admin-status-list">
                        @foreach (var row in userTaskStats.OrderBy(row => row.Key))
                        {
                            <li><span>@row.Key</span><strong>@row.Value</strong></li>
                        }
                    </ul>
                </section>

                <section>
                    <h3>Group tasks</h3>
                    <ul class="admin-status-list">
                        @foreach (var row in groupTaskStats.OrderBy(row => row.Key))
                        {
                            <li><span>@row.Key</span><strong>@row.Value</strong></li>
                        }
                    </ul>
                </section>

                <section>
                    <h3>All tasks</h3>
                    <ul class="admin-status-list">
                        @foreach (var row in totalTaskStats.OrderBy(row => row.Key))
                        {
                            <li><span>@row.Key</span><strong>@row.Value</strong></li>
                        }
                    </ul>
                </section>
            </div>
        </article>
    </div>
</section>