@using StudyHub.Domain.Enums
@using StudyHub.Domain.Entities
@model Application.Models.AdminRequestsViewModel
@{
    ViewData["Title"] = "Requests";
    var isModalOpen = Model.OpenRequestModal;
    var allowedStatuses = Model.AllowedStatuses;
    var activeRequestComments = Model.ActiveRequestComments ?? [];

    string StatusLabel(Status status) => status switch
    {
        Status.ToDo => "To do",
        Status.InProgress => "In progress",
        Status.Resolved => "Resolved",
        _ => status.ToString()
    };

    string FeedbackTypeLabel(FeedbackType type) => type switch
    {
        FeedbackType.Issue => "Issue",
        FeedbackType.Request => "Request",
        FeedbackType.Question => "Question",
        _ => type.ToString()
    };

    string CategoryLabel(Category category) => category switch
    {
        Category.UserManagement => "User management",
        Category.TaskBoard => "Task board",
        Category.UserProfile => "User profile",
        _ => category.ToString()
    };

    (string Subject, string Body) ParseRequestSummary(string? rawDescription)
    {
        var description = (rawDescription ?? string.Empty)
            .Replace("\r\n", "\n")
            .Trim();

        string NormalizeBody(string text)
        {
            var cleanText = text
                .Replace("\u00A0", " ")
                .Replace("\u200B", string.Empty)
                .Replace("\uFEFF", string.Empty);

            var lines = cleanText
                .Split('\n', StringSplitOptions.None)
                .Select(line => line.Trim())
                .Where(line => !string.IsNullOrWhiteSpace(line))
                .ToArray();

            return string.Join(" ", lines).Trim();
        }

        if (string.IsNullOrWhiteSpace(description))
        {
            return ("(No subject)", string.Empty);
        }

        var lines = description.Split('\n', 2, StringSplitOptions.None);
        var firstLine = lines[0].Trim();
        const string subjectPrefix = "Subject:";

        if (firstLine.StartsWith(subjectPrefix, StringComparison.OrdinalIgnoreCase))
        {
            var subject = firstLine[subjectPrefix.Length..].Trim();
            var body = lines.Length > 1 ? NormalizeBody(lines[1]) : string.Empty;

            return (string.IsNullOrWhiteSpace(subject) ? "(No subject)" : subject, body);
        }

        return (firstLine, NormalizeBody(description));
    }

    var activeRequest = Model.ActiveRequest;
    var activeSummary = activeRequest == null
        ? ("(No subject)", string.Empty)
        : ParseRequestSummary(activeRequest.Description);
}

<style>
.admin-requests-page { background: #fff; border: 1px solid #d2d8e0; border-radius: 12px; padding: 16px 14px 14px; margin-top: 10px; }
.admin-requests-head { display: flex; justify-content: flex-start; align-items: center; gap: 12px; margin-bottom: 14px; }
.admin-requests-head h1 { margin: 0; font-size: 2rem; font-weight: 500; font-family: 'Archivo', 'Trebuchet MS', sans-serif; letter-spacing: 0; color: #1f2633; }
.admin-requests-toolbar { display: grid; grid-template-columns: 1fr auto; gap: 10px; margin-bottom: 10px; }
.admin-requests-toolbar input, .admin-requests-toolbar select, .admin-requests-toolbar button { min-height: 38px; border: 1px solid #9aa3af; border-radius: 9px; background: #fff; padding: 0 10px; }
.admin-requests-table { width: 100%; border-collapse: collapse; table-layout: fixed; }
.admin-requests-table th, .admin-requests-table td { border-bottom: 1px solid #e0e5eb; padding: 10px 8px; text-align: left; }
.admin-requests-table th { color: #646e7f; font-weight: 700; }
.admin-requests-table th:first-child,
.admin-requests-table td:first-child { width: 30%; overflow: hidden; }
.admin-requests-status { display: inline-flex; min-width: 92px; justify-content: center; align-items: center; min-height: 30px; border: 1px solid #7e8794; border-radius: 7px; font-weight: 700; font-size: 0.92rem; line-height: 1; }
.admin-requests-status.todo { background: #fff; }
.admin-requests-status.progress { background: #cfe5ff; border-color: #568dcc; }
.admin-requests-status.resolved { background: #cfe9c9; border-color: #6ea66a; }
.admin-requests-status-select { min-width: 132px; min-height: 32px; border: 1px solid #7e8794; border-radius: 7px; font-weight: 700; font-size: 0.92rem; background: #fff; padding: 0 8px; }
.admin-requests-status-select.todo { background: #fff; }
.admin-requests-status-select.progress { background: #cfe5ff; border-color: #568dcc; }
.admin-requests-status-select.resolved { background: #cfe9c9; border-color: #6ea66a; }
.admin-requests-view-link { color: inherit; text-decoration: none; }
.admin-requests-view-link:hover { text-decoration: underline; }
.admin-requests-subject-link {
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 100%;
}
.admin-requests-backdrop { position: fixed; inset: 0; background: rgba(20, 27, 40, 0.45); z-index: 120; }
.admin-request-review-modal { position: fixed; z-index: 130; top: 50%; left: 50%; transform: translate(-50%, -50%); width: min(1020px, 90vw); max-height: 86vh; overflow: auto; background: #fff; border: 1px solid #aeb6c2; border-radius: 14px; padding: 20px 22px; box-shadow: 0 22px 42px rgba(7, 13, 22, 0.28); }
.admin-request-review-top { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 14px; }
.admin-request-review-top h2 { margin: 0; font-size: clamp(1.55rem, 2.4vw, 2.2rem); font-weight: 800; color: #1f2633; }
.admin-request-review-title {
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 620px;
}
.admin-request-review-tools { display: inline-flex; align-items: center; gap: 8px; }
.admin-request-review-tools select, .admin-request-review-tools a { min-height: 38px; border: 1px solid #8d97a4; border-radius: 8px; background: #fff; padding: 5px 10px; color: #1f2633; text-decoration: none; }
.admin-request-review-grid { display: grid; grid-template-columns: 1.25fr 0.9fr; gap: 14px; }
.admin-request-review-block h3 { margin: 0 0 10px; font-size: 2rem; font-weight: 800; color: #1f2633; }
.admin-request-review-block h3::after { content: ""; display: block; width: 108px; margin-top: 4px; border-bottom: 2px solid #4a5466; }
.admin-request-review-description { margin-top: 20px; min-height: 260px; max-height: 340px; border: 1px solid #8d97a4; border-radius: 12px; padding: 14px; background: #fff; overflow-y: auto; }
.admin-request-review-description {
    white-space: normal;
    overflow-wrap: anywhere;
}
.admin-request-review-details { margin-top: 8px; }
.admin-request-review-details dl { margin: 0; display: grid; grid-template-columns: 98px 1fr; row-gap: 8px; column-gap: 8px; }
.admin-request-review-details dt { color: #4d5563; }
.admin-request-review-meta { margin-top: 12px; font-size: 0.95rem; color: #2c3444; }
.admin-request-review-meta-row { display: grid; grid-template-columns: 74px 1fr; gap: 8px; margin-top: 4px; }
.admin-request-review-resolved { display: none; }
.admin-request-review-resolved.is-visible { display: grid; }
.request-view-comments { margin-top: 18px; display: grid; gap: 14px; }
.request-view-comments h3 { margin: 0; font-size: 1.5rem; font-weight: 800; color: #1f2633; }
.request-view-comments h3::after { content: ""; display: block; width: 108px; margin-top: 4px; border-bottom: 2px solid #4a5466; }
.request-view-comment-list { display: grid; gap: 10px; }
.request-view-comment-item { display: flex; justify-content: space-between; gap: 12px; border: 1px solid #d9dee7; border-radius: 12px; padding: 12px 14px; background: #fafbfc; }
.request-view-comment-author { font-weight: 800; color: #1f2633; }
.request-view-comment-text { margin: 6px 0 0; color: #2c3444; white-space: pre-wrap; }
.request-view-comment-actions { flex-shrink: 0; align-self: center; }
.request-view-comment-delete-btn { border: 1px solid #c17b7b; background: #fff5f5; color: #9b2c2c; border-radius: 8px; min-height: 34px; padding: 0 12px; font-weight: 700; }
</style>

<section class="admin-requests-page">
    <form class="js-admin-requests-token" method="post" hidden>
        @Html.AntiForgeryToken()
    </form>

    <div class="admin-requests-head">
        <h1>All requests</h1>
    </div>

    <div class="admin-requests-toolbar">
        <input class="js-admin-requests-search" type="search" placeholder="Search" />
        <select class="js-admin-requests-status-filter" aria-label="Filter by status">
            <option value="">Filter by</option>
            @foreach (var status in allowedStatuses)
            {
                <option value="@status">@StatusLabel(status)</option>
            }
        </select>
    </div>

    <table class="admin-requests-table">
        <thead>
            <tr>
                <th>Subject</th>
                <th>Reporter</th>
                <th>Type</th>
                <th>Category</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Model.Requests)
            {
                var statusClass = row.Status == Status.Resolved ? "resolved" : row.Status == Status.InProgress ? "progress" : "todo";
                var summary = ParseRequestSummary(row.Description);

                <tr class="js-admin-request-row" data-status="@row.Status" data-feedback-id="@row.Id">
                    <td><a class="admin-requests-view-link admin-requests-subject-link" asp-controller="Admin" asp-action="RequestView" asp-route-feedbackId="@row.Id" title="@summary.Item1">@summary.Item1</a></td>
                    <td>@row.CreatorFullname</td>
                    <td>@FeedbackTypeLabel(row.FeedbackType)</td>
                    <td>@CategoryLabel(row.Category)</td>
                    <td>
                        <select class="admin-requests-status-select @statusClass js-admin-request-status" data-feedback-id="@row.Id" aria-label="Status for request @summary.Item1">
                            @foreach (var status in allowedStatuses)
                            {
                                <option value="@status" selected="@(status == row.Status ? "selected" : null)">@StatusLabel(status)</option>
                            }
                        </select>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>

@if (isModalOpen && activeRequest != null)
{
    <div class="admin-requests-backdrop" aria-hidden="true"></div>

    <section class="admin-request-review-modal" role="dialog" aria-modal="true" aria-label="Request review">
        <div class="admin-request-review-top">
            <h2 class="admin-request-review-title" title="@activeSummary.Item1">@activeSummary.Item1</h2>

            <div class="admin-request-review-tools">
                <form asp-controller="Admin" asp-action="UpdateRequestStatus" method="post" class="admin-request-review-tools js-admin-review-status-form">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="feedbackId" value="@activeRequest.Id" />
                    <select class="admin-requests-status-select js-admin-request-status js-admin-review-status" data-feedback-id="@activeRequest.Id" name="status" aria-label="Status">
                        @foreach (var status in allowedStatuses)
                        {
                            <option value="@status" selected="@(status == activeRequest.Status ? "selected" : null)">@StatusLabel(status)</option>
                        }
                    </select>
                </form>
                <a asp-controller="Admin" asp-action="Requests">&lt; Back to the list</a>
            </div>
        </div>

        <div class="admin-request-review-grid">
            <article class="admin-request-review-block">
                <h3>Description</h3>
                <div class="admin-request-review-description">
                    @(string.IsNullOrWhiteSpace(activeSummary.Item2)
                        ? "No additional description provided."
                        : activeSummary.Item2)
                </div>
            </article>

            <aside class="admin-request-review-block">
                <h3>Details</h3>
                <div class="admin-request-review-details">
                    <dl>
                        <dt>Request:</dt><dd>#@activeRequest.Id.ToString()[..8]</dd>
                        <dt>User name:</dt><dd>@activeRequest.CreatorFullname</dd>
                        <dt>Email:</dt><dd>@activeRequest.User?.Email</dd>
                        <dt>Category:</dt><dd>@CategoryLabel(activeRequest.Category)</dd>
                        <dt>Type:</dt><dd>@FeedbackTypeLabel(activeRequest.FeedbackType)</dd>
                    </dl>
                </div>

                <div class="admin-request-review-meta">
                    <div class="admin-request-review-meta-row">
                        <span>Created:</span><span>@activeRequest.CreatedAt.ToString("dd.MM.yyyy")</span>
                    </div>
                    <div class="admin-request-review-meta-row admin-request-review-resolved js-admin-review-resolved-row @(activeRequest.Status == Status.Resolved ? "is-visible" : string.Empty)">
                        <span>Resolved:</span><span>@(activeRequest.ResolvedAt?.ToString("dd.MM.yyyy") ?? "")</span>
                    </div>
                </div>
            </aside>
        </div>

        <section class="request-view-comments">
            <h3>Comments</h3>
            <div class="request-view-comment-list">
                @if (activeRequestComments.Count == 0)
                {
                    <p class="admin-request-review-description">No comments yet.</p>
                }
                else
                {
                    @foreach (var comment in activeRequestComments)
                    {
                        <article class="request-view-comment-item">
                            <div class="request-view-comment-main">
                                <div class="request-view-comment-author">@comment.UserName</div>
                                <p class="request-view-comment-text">@comment.Description</p>
                            </div>

                            <div class="request-view-comment-actions">
                                <form asp-controller="Admin" asp-action="DeleteRequestComment" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="feedbackId" value="@activeRequest.Id" />
                                    <input type="hidden" name="commentId" value="@comment.Id" />
                                    <button type="submit" class="request-view-comment-delete-btn">Delete</button>
                                </form>
                            </div>
                        </article>
                    }
                }
            </div>

            <form class="task-view-editor js-rich-editor" asp-controller="Admin" asp-action="AddRequestComment" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="feedbackId" value="@activeRequest.Id" />
                <div class="task-view-editor-head">
                    <div class="task-view-editor-tools" aria-label="Comment formatting">
                        <button class="task-view-tool-btn js-rich-format-btn" type="button" data-command="bold" aria-label="Bold">B</button>
                        <button class="task-view-tool-btn js-rich-format-btn" type="button" data-command="italic" aria-label="Italic"><em>I</em></button>
                        <button class="task-view-tool-btn js-rich-format-btn" type="button" data-command="underline" aria-label="Underline"><u>U</u></button>
                        <button class="task-view-tool-btn js-rich-format-btn" type="button" data-command="strikeThrough" aria-label="Strike through"><s>S</s></button>
                    </div>
                    <button class="task-view-comment-btn" type="submit">Add a comment</button>
                </div>
                <div class="task-view-comment-input js-rich-editor-input" contenteditable="true" role="textbox" aria-multiline="true" data-placeholder="Write a comment..." data-max-chars="1000"></div>
                <textarea class="visually-hidden js-rich-editor-hidden" name="description"></textarea>
                <div class="task-summary-counter js-rich-char-counter" aria-live="polite">0/1000</div>
            </form>
        </section>
    </section>
}

<script>
document.addEventListener("DOMContentLoaded", function () {
    const searchInput = document.querySelector(".js-admin-requests-search");
    const statusFilter = document.querySelector(".js-admin-requests-status-filter");
    const rows = Array.from(document.querySelectorAll(".js-admin-request-row"));
    const statusInputs = Array.from(document.querySelectorAll(".js-admin-request-status"));
    const reviewStatusForm = document.querySelector(".js-admin-review-status-form");
    const antiForgeryToken = document.querySelector(".js-admin-requests-token input[name='__RequestVerificationToken']")?.value;
    const resolvedRow = document.querySelector(".js-admin-review-resolved-row");
    const reviewFeedbackId = reviewStatusForm?.querySelector("input[name='feedbackId']")?.value || "";

    if (!searchInput || !statusFilter || rows.length === 0) {
        return;
    }

    function applyAdminRequestFilters() {
        const query = (searchInput.value || "").trim().toLowerCase();
        const selectedStatus = statusFilter.value || "";

        rows.forEach(function (row) {
            const rowText = (row.textContent || "").toLowerCase();
            const rowStatus = row.dataset.status || "";

            const matchesQuery = query === "" || rowText.includes(query);
            const matchesStatus = selectedStatus === "" || rowStatus === selectedStatus;

            row.hidden = !(matchesQuery && matchesStatus);
        });
    }

    searchInput.addEventListener("input", applyAdminRequestFilters);
    statusFilter.addEventListener("change", applyAdminRequestFilters);

    function statusClassByValue(value) {
        if (value === "Resolved") return "resolved";
        if (value === "InProgress") return "progress";
        return "todo";
    }

    function applyStatusClass(select) {
        if (!select) {
            return;
        }

        select.classList.remove("todo", "progress", "resolved");
        select.classList.add(statusClassByValue(select.value));
    }

    function syncResolvedMeta(statusValue, feedbackId) {
        if (!resolvedRow) {
            return;
        }

        if (!feedbackId || !reviewFeedbackId || feedbackId !== reviewFeedbackId) {
            return;
        }

        resolvedRow.classList.toggle("is-visible", statusValue === "Resolved");
    }

    function syncAllStatusDropdowns(feedbackId, statusValue) {
        statusInputs
            .filter(select => select.dataset.feedbackId === feedbackId)
            .forEach(select => {
                if (select.value !== statusValue) {
                    select.value = statusValue;
                }

                applyStatusClass(select);
            });

        const row = document.querySelector('.js-admin-request-row[data-feedback-id="' + feedbackId + '"]');
        if (row) {
            row.dataset.status = statusValue;
        }

        syncResolvedMeta(statusValue, feedbackId);

        if (typeof applyAdminRequestFilters === "function") {
            applyAdminRequestFilters();
        }
    }

    async function updateRequestStatus(select) {
        const feedbackId = select.dataset.feedbackId;
        const statusValue = select.value;

        if (!feedbackId || !antiForgeryToken) {
            window.location.reload();
            return;
        }

        const peerSelects = statusInputs.filter(item => item.dataset.feedbackId === feedbackId);
        peerSelects.forEach(item => {
            item.disabled = true;
        });

        const formData = new URLSearchParams();
        formData.append("feedbackId", feedbackId);
        formData.append("status", statusValue);
        formData.append("__RequestVerificationToken", antiForgeryToken);

        try {
            const response = await fetch("/Admin/Requests/UpdateStatus", {
                method: "POST",
                headers: {
                    "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8",
                    "X-Requested-With": "XMLHttpRequest"
                },
                body: formData.toString()
            });

            if (!response.ok) {
                throw new Error("Status update failed.");
            }

            const payload = await response.json();
            syncAllStatusDropdowns(payload.feedbackId, payload.status);
        } catch {
            window.location.reload();
        } finally {
            peerSelects.forEach(item => {
                item.disabled = false;
            });
        }
    }

    statusInputs.forEach(select => {
        applyStatusClass(select);

        select.addEventListener("change", function () {
            updateRequestStatus(select);
        });
    });

    const reviewSelect = document.querySelector(".js-admin-review-status");
    if (reviewSelect) {
        syncResolvedMeta(reviewSelect.value, reviewSelect.dataset.feedbackId || "");
    }
});
</script>
