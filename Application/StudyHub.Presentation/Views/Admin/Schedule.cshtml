@model Application.Models.AdminScheduleViewModel

<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Schedule Management</h2>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body">
            <div class="row align-items-center">
                <div class="col-md-4 border-end">
                    <div class="d-flex align-items-center mb-3">
                        <div class="me-3">
                            <form asp-action="RunGlobalUpdate" method="post">
                                <button type="submit" class="btn btn-outline-dark px-4">Update</button>
                            </form>
                        </div>
                        <div>
                            <p class="mb-0 fw-bold">Run global schedule update:</p>
                            <small class="text-muted">Last global update: @(Model.LastGlobalUpdate == DateTime.MinValue ? "Never" : Model.LastGlobalUpdate.ToString("dd.MM.yyyy"))</small>
                        </div>
                    </div>
                    <div class="d-flex align-items-center">
                        <div class="me-3">
                            <form asp-action="RemoveGlobalSchedule" method="post" onsubmit="return confirm('Ви впевнені, що хочете видалити розклад для ВСІХ груп?')">
                                <button type="submit" class="btn btn-outline-danger px-4">Remove</button>
                            </form>
                        </div>
                        <p class="mb-0 fw-bold">Run global schedule removal:</p>
                    </div>
                </div>

                <div class="col-md-8 ps-4">
                    <form asp-action="UpdateGlobalSettings" method="post" id="settingsForm">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-check form-switch mb-3">
                                    <input class="form-check-input" type="checkbox" id="autoUpdate" name="isAutoUpdate"
                                           @(Model.IsAutoUpdateEnabled ? "checked" : "") onchange="this.form.submit()">
                                    <label class="form-check-label fw-bold" for="autoUpdate">Schedule AutoUpdate</label>
                                </div>
                                <div class="d-flex align-items-center">
                                    <span class="me-2 fw-bold">Run AutoUpdate once in</span>
                                    <select class="form-select form-select-sm w-auto" name="intervalDays" onchange="this.form.submit()">
                                        <option value="1" selected="@(Model.AutoUpdateIntervalDays == 1)">1</option>
                                        <option value="3" selected="@(Model.AutoUpdateIntervalDays == 3)">3</option>
                                        <option value="7" selected="@(Model.AutoUpdateIntervalDays == 7)">7</option>
                                    </select>
                                    <span class="ms-2 fw-bold">days</span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="allowLeaders" name="allowLeaders"
                                           @(Model.AllowLeadersToUpdate ? "checked" : "") onchange="this.form.submit()">
                                    <label class="form-check-label fw-bold" for="allowLeaders">Allow leaders to update the schedule</label>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="d-flex align-items-center">
            <select class="form-select me-3" style="min-width: 200px;" onchange="window.location.href='/Admin/Schedule/' + this.value">
                <option value="">Select Group...</option>
                @foreach (var group in Model.Groups)
                {
                    <option value="@group.Id" selected="@(Model.SelectedGroupId == group.Id)">@group.Name</option>
                }
            </select>
            @if (Model.SelectedGroupId.HasValue && Model.CurrentGroupSchedule != null)
            {
                <span class="text-muted small">Last update: @Model.CurrentGroupSchedule.GroupName</span>
            }
        </div>

        @if (Model.SelectedGroupId.HasValue)
        {
            <div class="d-flex gap-2">
                <form asp-action="UpdateGroupSchedule" method="post">
                    <input type="hidden" name="groupId" value="@Model.SelectedGroupId" />
                    <button type="submit" class="btn btn-outline-dark">Update schedule for current group</button>
                </form>
                <form asp-action="RemoveGroupSchedule" method="post" onsubmit="return confirm('Видалити розклад для цієї групи?')">
                    <input type="hidden" name="groupId" value="@Model.SelectedGroupId" />
                    <button type="submit" class="btn btn-outline-danger">Remove schedule for current group</button>
                </form>
            </div>
        }
    </div>

    @if (Model.SelectedGroupId.HasValue && Model.CurrentGroupSchedule != null)
    {
        @await Html.PartialAsync("_ScheduleGridPartial", Model.CurrentGroupSchedule)
    }
    else
    {
        <div class="text-center py-5 border-2 border-dashed rounded bg-white">
            <p class="text-muted mb-0">Please select a group to view its schedule.</p>
        </div>
    }
</div>


@section Styles {
    <style>
        .schedule-table {
            width: 100%;
            border-collapse: collapse;
            table-layout: fixed;
            background: white;
        }

            .schedule-table th, .schedule-table td {
                border: 1px solid #dee2e6;
                padding: 8px;
            }

            .schedule-table th {
                background: #f8f9fa;
                text-align: center;
            }

        .lesson-card {
            border: 1px solid #ccc;
            border-radius: 8px;
            padding: 5px;
            position: relative;
            min-height: 70px;
            margin-bottom: 4px;
        }

        .lesson-badge {
            background: black;
            color: white;
            border-radius: 4px;
            padding: 2px 5px;
            font-weight: bold;
            font-size: 10px;
            position: absolute;
            top: 5px;
            left: 5px;
        }

        .lesson-subject {
            text-align: center;
            font-weight: 600;
            margin-top: 15px;
            font-size: 13px;
        }

        .lesson-footer {
            display: flex;
            justify-content: space-between;
            font-size: 10px;
            margin-top: 5px;
            color: #555;
        }
    </style>
}