@model Application.Models.UpdateUserViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Edit user";
}

<section class="admin-page" aria-label="Edit user page">
    <div class="admin-page-header admin-page-header-inline">
        <div>
            <h1>Edit user</h1>
            <p class="admin-page-subtitle">@Model.Name @Model.Surname</p>
        </div>
        <a asp-action="Users" class="admin-btn">Back to user management</a>
    </div>

    <div class="admin-dashboard-grid">
        <article class="admin-panel" style="grid-column: 1 / -1;">
            <h2>User access</h2>

            <form asp-action="UpdateUser" method="post" class="admin-form-stack" style="margin-top: 10px;">
                <input type="hidden" name="id" value="@Model.Id" />

                <div>
                    <label asp-for="GroupName" class="admin-label">Group</label>
                    <input asp-for="GroupName" class="admin-input" list="existing-groups" autocomplete="off" />
                    <datalist id="existing-groups">
                        @foreach (var groupName in Model.ExistingGroups)
                        {
                            <option value="@groupName"></option>
                        }
                    </datalist>
                </div>

                <div class="admin-actions-inline">
                    <button type="submit" class="admin-btn admin-btn-primary">Save group</button>
                </div>
            </form>

            <h3 style="margin-top:16px;">Roles</h3>

            <form asp-action="AddUserRole" method="post" class="admin-actions-inline" style="margin-top: 10px;">
                <input type="hidden" name="Id" value="@Model.Id" />

                <select name="Role" class="admin-input" style="max-width: 280px;">
                    <option selected disabled>Select role to add</option>
                    @foreach (var availableRole in Model.AvailableRoles.Where(r => !Model.Roles.Contains(r)))
                    {
                        <option value="@availableRole">@availableRole</option>
                    }
                </select>
                <button type="submit" class="admin-btn admin-btn-primary">Add</button>
            </form>

            <div class="admin-table-wrap" style="margin-top: 12px;">
                <table class="admin-table">
                    <thead>
                    <tr>
                        <th>Current role</th>
                        <th>Action</th>
                    </tr>
                    </thead>
                    <tbody>
                    @if (!Model.Roles.Any())
                    {
                        <tr>
                            <td colspan="2" class="text-muted">No roles assigned</td>
                        </tr>
                    }
                    @foreach (var role in Model.Roles)
                    {
                        <tr>
                            <td>@role</td>
                            <td>
                                <form asp-action="RemoveUserRole" method="post">
                                    <input type="hidden" name="Id" value="@Model.Id" />
                                    <input type="hidden" name="Role" value="@role" />
                                    <button type="submit" class="admin-link-btn admin-link-btn-danger">Remove</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </article>
    </div>
</section>