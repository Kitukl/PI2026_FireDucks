<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - StudyHub.Presentation</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/StudyHub.Presentation.styles.css" asp-append-version="true"/>

    @await RenderSectionAsync("Styles", required: false)
</head>
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var requestPath = Context.Request.Path.Value ?? string.Empty;
    var isInsideAdminController = currentController.Equals("Admin", StringComparison.OrdinalIgnoreCase);
    var isAdminUser = isInsideAdminController;
}
<body class="@(isAdminUser ? "admin-body" : "app-body")">
@if (!isAdminUser)
{
    <header class="sh-header">
        <div class="sh-header-top">
            <a class="sh-brand" asp-area="" asp-controller="Dashboard" asp-action="Index">
                <span class="sh-brand-icon" aria-hidden="true">
                    <img src="~/images/SHLogo.png" alt="" />
                </span>
                <span class="sh-brand-text"><span class="sh-brand-study">STUDY</span><span class="sh-brand-hub">HUB</span></span>
            </a>

            <nav class="sh-nav" aria-label="Primary">
                <a class="sh-nav-link @(currentController == "Dashboard" && currentAction == "Index" ? "active" : string.Empty)"
                   asp-area="" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                <a class="sh-nav-link @(currentController == "TaskBoard" ? "active" : string.Empty)"
                   asp-area="" asp-controller="TaskBoard" asp-action="TaskBoard">Task board</a>
                <a class="sh-nav-link @(currentController == "SchedulePage" ? "active" : string.Empty)"
                   asp-area="" asp-controller="Schedule" asp-action="MySchedule">Schedule</a>
                <a class="sh-nav-link @(currentController == "Storage" ? "active" : string.Empty)"
                   asp-area="" asp-controller="Storage" asp-action="Storage">Storage</a>
            </nav>

            <div class="sh-user-actions">
                <a class="sh-icon-btn" asp-area="" asp-controller="UserProfile" asp-action="UserProfile" aria-label="Profile">
                    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M12 13.2c2.76 0 5-2.24 5-5s-2.24-5-5-5-5 2.24-5 5 2.24 5 5 5zm0 2.4c-3.34 0-10 1.68-10 5v1.2h20V20.6c0-3.32-6.66-5-10-5z"></path>
                    </svg>
                </a>
                <a class="sh-logout-btn" asp-area="" asp-controller="User" asp-action="Logout">Log out</a>
            </div>
        </div>
    </header>
}
else
{
    <header class="sh-header sh-header-admin">
        <div class="sh-header-top sh-header-top-admin">
            <a class="sh-brand" asp-area="" asp-controller="Admin" asp-action="Dashboard">
                <span class="sh-brand-icon" aria-hidden="true">
                    <img src="~/images/SHLogo.png" alt="" />
                </span>
                <span class="sh-brand-text"><span class="sh-brand-study">STUDY</span><span class="sh-brand-hub">HUB</span></span>
                <span class="sh-admin-label">Administration</span>
            </a>

            <nav class="sh-nav" aria-label="Admin primary">
                <a class="sh-nav-link @(currentController == "Admin" && currentAction == "Dashboard" ? "active" : string.Empty)"
                   asp-area="" asp-controller="Admin" asp-action="Dashboard">Dashboard</a>
                <a class="sh-nav-link @(currentController == "Admin" && (currentAction == "Users" || currentAction == "GetUser") ? "active" : string.Empty)"
                         asp-area="" asp-controller="Admin" asp-action="Users">User management</a>
                <a class="sh-nav-link @(currentController == "Admin" && (currentAction == "Requests" || currentAction == "RequestView") ? "active" : string.Empty)"
                   asp-area="" asp-controller="Admin" asp-action="Requests">Requests</a>
                     <a class="sh-nav-link @(currentController == "Admin" && currentAction == "Schedule" ? "active" : string.Empty)"
                   asp-area="" asp-controller="Admin" asp-action="Schedule">Schedule</a>
            </nav>

            <div class="sh-user-actions sh-user-actions-admin">
                <a class="sh-logout-btn" asp-area="" asp-controller="User" asp-action="Logout">Log out</a>
            </div>
        </div>
    </header>
}

<div class="app-shell">
    <main role="main" class="@(isAdminUser ? "pb-3 app-main" : "app-main")">
        @RenderBody()
    </main>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>