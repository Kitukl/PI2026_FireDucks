@model IEnumerable<StudyHub.Core.DTOs.GroupDto>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-people"></i> Академічні групи</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Додати групу
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center">
            Груп поки що не створено. Натисніть "Додати групу", щоб почати.
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var item in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@item.Name</h5>
                            <p class="text-muted small">ID: @item.Id</p>
                        </div>
                        <div class="card-footer bg-transparent border-top-0 d-flex justify-content-between">
                            <div class="btn-group">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Редагувати</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Видалити групу?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Видалити</button>
                                </form>
                            </div>
                            <a asp-controller="Schedule" asp-action="ScheduleCreate" asp-route-groupId="@item.Id" class="btn btn-sm btn-success">
                                📅 Розклад
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>