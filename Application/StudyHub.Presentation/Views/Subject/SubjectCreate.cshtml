@model StudyHub.Core.DTOs.SubjectDto

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Новий предмет</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Назва предмету</label>
                            <input asp-for="Name" class="form-control" autofocus placeholder="Напр: Вища математика" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <a asp-action="SubjectsList" class="btn btn-outline-secondary">Скасувати</a>
                            <button type="submit" class="btn btn-success px-4">Створити</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>